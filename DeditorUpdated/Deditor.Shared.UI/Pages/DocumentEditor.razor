    // Validate required fields based on XML Type. Collects ALL errors into _metaErrors
    // (keyed by field name) so every invalid field can show its own inline message.
    private bool ValidateMetadata()
    {
        _metaErrors.Clear();
        if (string.IsNullOrWhiteSpace(_meta.Publisher))
            _metaErrors["Publisher"] = "Publisher Name is required.";
        if (_meta.XmlType == "Book")
        {
            if (!string.IsNullOrWhiteSpace(_meta.Isbn)
                && !System.Text.RegularExpressions.Regex.IsMatch(_meta.Isbn.Replace("-",""), @"^\d{10}(\d{3})?$"))
                _metaErrors["Isbn"] = "ISBN must be 10 or 13 digits.";
            if (!string.IsNullOrWhiteSpace(_meta.Year)
                && !System.Text.RegularExpressions.Regex.IsMatch(_meta.Year, @"^\d{4}$"))
                _metaErrors["Year"] = "Year must be a 4-digit number.";
        }
        else // Journal
        {
            if (string.IsNullOrWhiteSpace(_meta.JournalName))
                _metaErrors["JournalName"] = "Journal Name is required.";
            if (string.IsNullOrWhiteSpace(_meta.JournalTitle))
                _metaErrors["JournalTitle"] = "Journal Title is required.";
            if (string.IsNullOrWhiteSpace(_meta.PIssn))
                _metaErrors["PIssn"] = "P-ISSN is required.";
            if (string.IsNullOrWhiteSpace(_meta.Dtd))
                _metaErrors["Dtd"] = "DTD is required.";
            if (string.IsNullOrWhiteSpace(_meta.PublisherImprint))
                _metaErrors["PublisherImprint"] = "Publisher Imprint is required.";
        }
        if (!string.IsNullOrWhiteSpace(_meta.Doi)
            && !_meta.Doi.StartsWith("10.", StringComparison.OrdinalIgnoreCase))
            _metaErrors["Doi"] = "DOI must begin with \"10.\" (e.g. 10.1234/abcd).";
        return _metaErrors.Count == 0;
    }

    private async Task SaveMetadata()
    {
        if (!ValidateMetadata())
        {
            // Single toast for the whole form — per-field messages render inline below each input.
            SetStatus($"⚠ Please fix {_metaErrors.Count} highlighted field(s).", true);
            StateHasChanged();
            return;
        }
        _metaErrors.Clear();

        if (ActiveTab == null)
        {
            SetStatus("❌ No active document", true);
            return;
        }
        var tabId = ActiveTab.Id;

        try
        {
            // Persist per-document via JS (localStorage keyed by tabId)
            var ok = await JSRuntime.InvokeAsync<bool>("saveIPubEditMeta", tabId.ToString(), _meta);
            if (!ok)
            {
                SetStatus("❌ Metadata save failed", true);
                return;
            }
            // Update in-memory cache
            _metaByTab[tabId] = _meta;
            _metaLoadedTabs.Add(tabId);

            // Bind to editor (token replacement + future content controls)
            try { await JSRuntime.InvokeVoidAsync("applyMetadata", _meta); } catch { }

            SetStatus("✅ Metadata saved", false);
            Console.WriteLine("[iPubEdit] " + System.Text.Json.JsonSerializer.Serialize(_meta));

            // Persist updated metadata back into the DOCX customXml (iCore part).
            // Best-effort: errors are logged but don't block the dialog from closing.
            try
            {
                Console.WriteLine($"[SaveMetadata] Triggering customXml write-back for tab {tabId}");
                var dtoJson = System.Text.Json.JsonSerializer.Serialize(_meta);
                var result = await JSRuntime.InvokeAsync<string>("updateCustomXmlForActiveTab", tabId.ToString(), dtoJson);
                Console.WriteLine($"[SaveMetadata] updateCustomXmlForActiveTab result = '{result}'");
                switch (result)
                {
                    case "OK":
                        SetStatus("✅ Metadata saved & DOCX updated", false);
                        break;
                    case "NO_HANDLE":
                        Console.WriteLine("[SaveMetadata] No file handle — DOCX not updated on disk (file likely opened via upload).");
                        break;
                    case "PERMISSION_DENIED":
                        SetStatus("⚠ Metadata saved, but write permission was denied — DOCX not updated.", true);
                        break;
                    case "DELETED":
                        SetStatus("⚠ Metadata saved, but the source DOCX is missing on disk.", true);
                        break;
                    default:
                        if (result?.StartsWith("ERROR:") == true)
                            Console.WriteLine($"[SaveMetadata] customXml update error: {result}");
                        break;
                }
            }
            catch (Exception cxmlEx)
            {
                Console.WriteLine($"[SaveMetadata] customXml write-back EXCEPTION: {cxmlEx.Message}");
            }
        }
        catch (Exception ex)
        {
            SetStatus($"❌ {ex.Message}", true);
            return;
        }
        _showMetaDialog = false;
        StateHasChanged();
    }

