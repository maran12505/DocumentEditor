@page "/"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@using Deditor.Core.Services.Interfaces
@using Deditor.Core.Models
@inject IJSRuntime JSRuntime
@inject IDocumentService DocumentService
@inject IAiService AiService
@inject IManuscriptService ManuscriptService
@inject IAppConfig AppConfig

<style>
    .avatar { width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#2383E2,#062b4f);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff; }
    .logo { display:flex;align-items:center;gap:8px;font-weight:600;font-size:16px; }
    .logo-img { width:28px;height:28px;object-fit:contain;border-radius:6px; }
    .logo-text { font-size:15px;color:#2f2f2f; }

    .n-autosave-chip {
        display:inline-flex;align-items:center;gap:5px;font-size:.71rem;font-weight:500;
        color:var(--n-text-3);padding:2px 8px;border-radius:100px;
        transition:color .3s,background .3s;white-space:nowrap;user-select:none;
    }
    .n-autosave-chip.saved { color:var(--n-green);background:var(--n-green-bg); }

    .n-recovery-banner {
        display:flex;align-items:center;gap:10px;padding:9px 16px;
        background:#FFF8E6;border-bottom:1px solid #F5D87A;
        font-size:.8rem;color:#6B4A00;flex-shrink:0;flex-wrap:wrap;
    }
    [data-theme="dark"] .n-recovery-banner { background:#2A2210;border-bottom-color:#5A4500;color:#F5C842; }
    .n-recovery-banner-text { flex:1;line-height:1.4; }
    .n-recovery-btn { padding:4px 12px;border-radius:5px;border:none;font-size:.77rem;font-weight:600;font-family:inherit;cursor:pointer;transition:background .12s;white-space:nowrap; }
    .n-recovery-btn-restore { background:#F5C842;color:#3A2800; }
    .n-recovery-btn-restore:hover { background:#F0B800; }
    [data-theme="dark"] .n-recovery-btn-restore { background:#7A6000;color:#FFE580; }
    .n-recovery-btn-dismiss { background:transparent;color:#6B4A00;border:1px solid #D4AB30; }
    .n-recovery-btn-dismiss:hover { background:rgba(0,0,0,.06); }
    [data-theme="dark"] .n-recovery-btn-dismiss { color:#F5C842;border-color:#5A4500; }

    .n-sheet-tab-dirty { display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--n-amber);flex-shrink:0;margin-left:1px; }

    .n-focus-mode .n-topbar,
    .n-focus-mode .n-left-sidebar,
    .n-focus-mode .n-ai-sidebar,
    .n-focus-mode .n-sheet-bar { display:none !important; }
    .n-focus-mode .n-ribbon-left,
    .n-focus-mode .n-ribbon-right { display:none !important; }
    .n-focus-mode .n-main { flex:1; }
.n-focus-exit {
    position: fixed;
    top: 12px;
    right: 14px;
    z-index: 9999;
    background: rgba(0,0,0,.45);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 8px;
    cursor: pointer;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .15s;
}
.n-focus-exit:hover {
    background: rgba(0,0,0,.7);
}
.n-focus-exit svg {
    display: block;
}

    .n-slash-picker {
        position:fixed;z-index:9998;background:var(--n-surface);
        border:1px solid var(--n-border);border-radius:8px;
        box-shadow:0 8px 24px rgba(0,0,0,.14);min-width:220px;max-height:260px;overflow-y:auto;
        font-family:inherit;padding:4px;
    }
    .n-slash-item {
        display:flex;align-items:center;gap:8px;padding:7px 10px;
        border-radius:5px;cursor:pointer;font-size:.8rem;color:var(--n-text-2);
        transition:background .1s,color .1s;
    }
    .n-slash-item:hover, .n-slash-item.n-slash-active { background:var(--n-hover);color:var(--n-text); }
    .n-slash-icon { font-size:.85rem;flex-shrink:0;width:20px;text-align:center; }
    .n-slash-label { font-weight:600;color:var(--n-text);font-size:.78rem; }
    .n-slash-desc  { font-size:.68rem;color:var(--n-text-3); }
    .n-slash-header { font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--n-text-3);padding:6px 10px 3px; }

    .n-left-tabs { display:flex;gap:0;padding:0 8px;border-bottom:1px solid var(--n-border-soft);flex-shrink:0;background:var(--n-surface); }
    .n-left-tab {
        padding:7px 9px;font-size:.7rem;font-weight:600;color:var(--n-text-3);
        cursor:pointer;border-bottom:2px solid transparent;transition:color .1s,border-color .1s;
        white-space:nowrap;user-select:none;
    }
    .n-left-tab:hover { color:var(--n-text); }
    .n-left-tab.active { color:var(--n-text);border-bottom-color:var(--n-accent); }

    .n-sidebar-section { padding: 14px 14px 12px; }
    .n-sidebar-section + .n-sidebar-section { border-top: 1px solid var(--n-border-soft); }
    .n-sidebar-section-label {
        font-size: .6rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .8px; color: var(--n-text-3); margin-bottom: 10px;
        display: flex; align-items: center; gap: 6px; user-select: none;
    }

    .n-file-card {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 11px; border-radius: 8px;
        background: var(--n-hover); transition: background .15s;
    }
    .n-file-card:hover { background: var(--n-active); }
    .n-file-card-icon {
        width: 34px; height: 34px; border-radius: 7px;
        background: var(--n-accent); display: flex;
        align-items: center; justify-content: center; flex-shrink: 0;
    }
    .n-file-card-icon svg { color: #fff; }
    .n-file-card-info { flex: 1; min-width: 0; }
    .n-file-card-name {
        font-size: .8rem; font-weight: 600; color: var(--n-text);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap; line-height: 1.3;
    }
    .n-file-card-meta {
        font-size: .66rem; color: var(--n-text-3);
        display: flex; align-items: center; gap: 4px; margin-top: 2px;
    }
    .n-file-card-meta svg { flex-shrink: 0; opacity: .6; }

    .n-stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .n-stat-card {
        background: var(--n-hover); border-radius: 8px;
        padding: 10px 12px; display: flex; flex-direction: column;
        gap: 3px; transition: background .15s;
    }
    .n-stat-card:hover { background: var(--n-active); }
    .n-stat-value {
        font-size: 1.1rem; font-weight: 700; color: var(--n-text);
        line-height: 1; letter-spacing: -.02em;
    }
    .n-stat-label {
        font-size: .58rem; color: var(--n-text-3);
        text-transform: uppercase; letter-spacing: .5px; font-weight: 600;
    }

    .n-stats-footer {
        display: flex; align-items: center; justify-content: space-between;
        margin-top: 10px; padding: 7px 10px;
        background: var(--n-hover); border-radius: 7px;
        font-size: .71rem; color: var(--n-text-2);
    }
    .n-stats-footer-value { font-weight: 700; color: var(--n-text); }

    .n-refresh-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 12px;
        border: 1px solid var(--n-border); border-radius: 10px;
        background: transparent; color: var(--n-text-3);
        font-size: .7rem; font-weight: 600; font-family: inherit;
        cursor: pointer; transition: background .12s, color .12s, border-color .12s;
        user-select: none; margin-left: 40px;
    }
    .n-refresh-btn:hover { background: var(--n-hover); color: var(--n-text); border-color: var(--n-text-3); }
    .n-refresh-btn:active { background: var(--n-active); }
    .n-refresh-btn svg { opacity: .6; transition: opacity .12s; }
    .n-refresh-btn:hover svg { opacity: 1; }

    .n-outline-item { display:flex;align-items:center;gap:5px;padding:5px 6px;border-radius:4px;cursor:pointer;font-size:.76rem;color:var(--n-text-2);transition:background .1s,color .1s;line-height:1.3; }
    .n-outline-item:hover { background:var(--n-hover);color:var(--n-text); }
    .n-outline-h1 { padding-left:6px;font-weight:600;color:var(--n-text); }
    .n-outline-h2 { padding-left:18px; }
    .n-outline-h3 { padding-left:30px;font-size:.72rem; }
    .n-outline-dot { width:5px;height:5px;border-radius:50%;flex-shrink:0; }
    .n-outline-h1 .n-outline-dot { background:var(--n-accent); }
    .n-outline-h2 .n-outline-dot { background:var(--n-text-3); }
    .n-outline-h3 .n-outline-dot { background:var(--n-border); }

    .n-recent-item { display:flex;align-items:center;gap:7px;padding:6px 8px;border-radius:5px;cursor:pointer;transition:background .1s; }
    .n-recent-item:hover { background:var(--n-hover); }
    .n-recent-name { font-size:.77rem;font-weight:500;color:var(--n-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1; }
    .n-recent-time { font-size:.65rem;color:var(--n-text-3);flex-shrink:0; }

    /* ── File Not Found Modal ────────────────────────────────────────── */
    .n-modal-overlay {
        position: fixed; inset: 0; z-index: 10000;
        background: rgba(0,0,0,.45);
        display: flex; align-items: center; justify-content: center;
        animation: n-fade-in .15s ease;
    }
    [data-theme="dark"] .n-modal-overlay { background: rgba(0,0,0,.65); }
    @@keyframes n-fade-in { from { opacity: 0; } to { opacity: 1; } }

    .n-modal {
        background: var(--n-surface, #fff);
        border: 1px solid var(--n-border, #e0e0e0);
        border-radius: 12px;
        box-shadow: 0 16px 48px rgba(0,0,0,.18);
        width: 440px; max-width: 92vw;
        padding: 0;
        animation: n-slide-up .2s ease;
        font-family: inherit;
    }
    @@keyframes n-slide-up { from { transform: translateY(12px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .n-modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 22px 14px;
        border-bottom: 1px solid var(--n-border-soft, #f0f0f0);
    }
    .n-modal-header h3 {
        margin: 0; font-size: .95rem; font-weight: 700;
        color: var(--n-text, #2f2f2f);
        display: flex; align-items: center; gap: 8px;
    }
    .n-modal-close {
        background: none; border: none; cursor: pointer;
        color: var(--n-text-3, #999); font-size: 1.1rem;
        width: 28px; height: 28px; border-radius: 6px;
        display: flex; align-items: center; justify-content: center;
        transition: background .12s, color .12s;
    }
    .n-modal-close:hover { background: var(--n-hover, #f5f5f5); color: var(--n-text, #2f2f2f); }

    .n-modal-body {
        padding: 18px 22px 22px;
        font-size: .84rem; color: var(--n-text-2, #555);
        line-height: 1.55;
    }
    .n-modal-body strong { color: var(--n-text, #2f2f2f); }
    .n-modal-body code {
        background: var(--n-hover, #f5f5f5); padding: 2px 6px;
        border-radius: 4px; font-size: .78rem;
        word-break: break-all;
    }

    .n-modal-footer {
        display: flex; align-items: center; justify-content: flex-end;
        gap: 8px; padding: 12px 22px 18px;
    }
    .n-modal-btn {
        padding: 8px 18px; border-radius: 7px;
        font-size: .8rem; font-weight: 600;
        font-family: inherit; cursor: pointer;
        transition: background .12s, color .12s, border-color .12s;
        border: 1px solid transparent;
    }
    .n-modal-btn-secondary {
        background: transparent; color: var(--n-text-2, #666);
        border-color: var(--n-border, #e0e0e0);
    }
    .n-modal-btn-secondary:hover { background: var(--n-hover, #f5f5f5); color: var(--n-text, #2f2f2f); }
    .n-modal-btn-primary {
        background: var(--n-accent, #2383E2); color: #fff;
        border-color: var(--n-accent, #2383E2);
    }
    .n-modal-btn-primary:hover { filter: brightness(1.08); }

    /* ── Save group in topbar ────────────────────────────────────────── */
    .n-save-group {
        display: flex; align-items: center; gap: 2px;
    }
    .n-save-group .n-btn { font-size: .72rem; gap: 4px; }
    .n-save-group .n-btn svg { flex-shrink: 0; }

    /* ── Toast notification ─────────────────────────────────────────── */
    .n-toast {
        position: fixed; top: 16px; left: 50%; transform: translateX(-50%);
        z-index: 10000; display: flex; align-items: center; gap: 8px;
        padding: 10px 18px; border-radius: 10px;
        font-family: 'DM Sans', 'Segoe UI', system-ui, sans-serif;
        font-size: .78rem; font-weight: 500;
        box-shadow: 0 4px 20px rgba(0,0,0,.12), 0 1px 4px rgba(0,0,0,.08);
        cursor: pointer; user-select: none; white-space: nowrap;
        animation: toastIn .25s ease-out;
    }
    @@keyframes toastIn {
        from { opacity: 0; transform: translateX(-50%) translateY(-12px); }
        to   { opacity: 1; transform: translateX(-50%) translateY(0); }
    }
    .n-toast-icon {
        width: 20px; height: 20px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: .65rem; font-weight: 700; flex-shrink: 0;
    }
    .n-toast-close {
        margin-left: 6px; font-size: .65rem; opacity: .4;
        transition: opacity .12s;
    }
    .n-toast:hover .n-toast-close { opacity: .8; }
    .n-toast-msg { max-width: 360px; overflow: hidden; text-overflow: ellipsis; }

    /* ── iPubEdit Meta Information Modal ─────────────────────────────── */
    .ipub-modal {
        background: var(--n-surface, #fff);
        border: 1px solid var(--n-border, #e0e0e0);
        border-radius: 10px;
        box-shadow: 0 20px 60px rgba(0,0,0,.22);
        width: 920px; max-width: 96vw; max-height: 90vh;
        display: flex; flex-direction: column;
        font-family: inherit;
        animation: n-slide-up .2s ease;
    }
    .ipub-title {
        display: flex; align-items: center; justify-content: space-between;
        padding: 10px 14px;
        background: #E4E2DE !important;
        color: #2c2b27; border-radius: 10px 10px 0 0;
        font-size: .82rem; font-weight: 600; letter-spacing: .2px;
    }
    .ipub-title .ipub-close {
        background: transparent; border: none; color: #2c2b27; cursor: pointer;
        width: 22px; height: 22px; border-radius: 4px; font-size: 1rem;
        display: flex; align-items: center; justify-content: center;
        transition: background .12s;
    }
    .ipub-title .ipub-close:hover { background: rgba(255,255,255,.18); }
    .ipub-toolbar {
        display: flex; justify-content: flex-end;
        padding: 6px 14px;
        background: #f5f5f3;
        border-bottom: 1px solid var(--n-border-soft, #e4e2dc);
    }
    [data-theme="dark"] .ipub-toolbar { background: #2a2a2a; border-bottom-color: #3a3a3a; }
    .ipub-save-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 14px; font-size: .76rem; font-weight: 600 !important;
        color: #ffffff !important;
        background: #2C2B27 !important; border: none !important;
        border-radius: 6px !important; cursor: pointer; font-family: inherit;
        transition: background .12s, border-color .12s;
        box-shadow: 0 1px 3px rgba(0, 0, 0, .18) !important;
    }
    .ipub-save-btn:hover { background: var(--n-hover, #eeeae2); border-color: var(--n-border, #d6d4cf); }
  

    .ipub-body { padding: 14px 18px; overflow-y: auto; flex: 1; }
    .ipub-section {
        border: 1px solid var(--n-border, #d6d4cf);
        border-radius: 6px;
        padding: 12px 14px 14px;
        margin-bottom: 12px;
        background: var(--n-surface, #fff);
    }
    .ipub-section-title {
        font-size: .72rem; font-weight: 700; color: var(--n-text-2, #444);
        margin: -20px 0 10px; padding: 0 6px; display: inline-block;
        background: var(--n-surface, #fff);
    }
    .ipub-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px 16px;
        margin-bottom: 4px;
        align-items: end;
    }
    .ipub-row-4 { grid-template-columns: repeat(4, 1fr); }
    .ipub-row-2 { grid-template-columns: repeat(2, 1fr); }
    /* Vertical-stack field: small uppercase label on top, control below.
       Aligns every column on a consistent grid baseline. */
    .ipub-field {
        display: flex; flex-direction: column;
        gap: 4px; min-width: 0; font-size: .74rem;
        /* Reserve a fixed slot at the bottom for validation messages so rows
           never reflow when an error appears. The .ipub-err span is absolutely
           positioned into this slot. */
        position: relative;
        padding-bottom: 16px;
    }
    .ipub-field-full { grid-column: 1 / -1; }
    /* Bundled checkbox cell — both Copyedit + Pre-Editing share one .ipub-field. */
    .ipub-field.ipub-checks-field {
        flex-direction: row; align-items: center; gap: 16px;
        padding-bottom: 16px;
    }
    .ipub-label {
        font-size: .66rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: .04em;
        
        white-space: normal; flex-shrink: 0; margin: 0;
        line-height: 1.2;
    }
    .ipub-label .req { color: #D44C47; margin-left: 2px; }
    /* ── Syncfusion polish — flat white box style (matches legacy iPubEdit UI) ── */
    .ipub-body .e-input-group,
    .ipub-body .e-ddl.e-input-group,
    .ipub-body .e-textbox.e-input-group,
    .ipub-body .e-input-group.e-control-wrapper {
        font-size: .76rem !important;
        @* border: 1px solid #d1d5db !important;
        border-radius: 3px !important; *@
        border-radius:5px;
        background: #ffffff !important;
        box-shadow: none !important;
    }
    /* Kill Material's underline pseudo-elements */
    .ipub-body .e-input-group::before,
    .ipub-body .e-input-group::after,
    .ipub-body .e-input-group.e-control-wrapper::before,
    .ipub-body .e-input-group.e-control-wrapper::after {
        display: none !important;
        content: none !important;
        background: transparent !important;
    }
    .ipub-body .e-input-group .e-input,
    .ipub-body .e-input-group .e-control,
    .ipub-body .e-ddl input.e-input,
    .ipub-body .e-input-group input.e-input {
        font-size: .76rem !important;
        padding: 5px 8px !important;
        height: 20px;
        background: #ffffff !important;
        color: #2f2f2f !important;
    }
    .ipub-body .e-input-group:not(.e-disabled):hover,
    .ipub-body .e-input-group.e-control-wrapper:not(.e-disabled):hover {
        border-color: #9ca3af !important;
    }
    .ipub-body .e-input-group:not(.e-disabled).e-input-focus,
    .ipub-body .e-input-group.e-control-wrapper:not(.e-disabled).e-input-focus {
        border-color: #2383E2 !important;
        box-shadow: 0 0 0 2px rgba(35,131,226,.12) !important;
    }
    .ipub-body .e-input-group .e-input-group-icon,
    .ipub-body .e-input-group.e-control-wrapper .e-input-group-icon {
        font-size: .7rem; min-height: 30px;
        background: transparent !important;
        border: none !important;
    }
    /* Disabled state */
    .ipub-body .e-input-group.e-disabled,
    .ipub-body .e-input-group.e-control-wrapper.e-disabled {
        background: #f5f5f5 !important; opacity: .7;
    }
    /* ── Per-field validation (inline) ── */
    .ipub-field.ipub-invalid .e-input-group,
    .ipub-field.ipub-invalid .e-input-group.e-control-wrapper {
        border-color: #dc2626 !important;
        box-shadow: 0 0 0 2px rgba(220,38,38,.12) !important;
    }
    .ipub-field.ipub-invalid .ipub-label { color: #dc2626; }
    .ipub-err {
        /* Sits inside the .ipub-field's reserved padding-bottom slot.
           Absolute positioning means showing/hiding the message never
           changes the field's outer height — adjacent rows stay aligned. */
        position: absolute;
        left: 0; right: 0; bottom: 0;
        color: #dc2626; font-size: .68rem; line-height: 1.2;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        pointer-events: none;
    }
    /* Syncfusion dropdown popup — keep inside modal-friendly z-index, capped height */
    .e-popup.e-ddl.e-popup-open { z-index: 100020 !important; }
    .e-popup.e-ddl .e-list-parent.e-ul { max-height: 240px !important; }
    /* Syncfusion checkbox spacing */
    .ipub-body .e-checkbox-wrapper { margin-right: 0; }
    .ipub-body .e-checkbox-wrapper .e-label {
        font-size: .76rem; color: var(--n-text-2, #444); margin-left: 6px;
    }
    .ipub-input, .ipub-select {
        flex: 1; min-width: 0;
        padding: 4px 7px; font-size: .76rem;
        border: 1px solid var(--n-border, #bcbcbc);
        border-radius: 3px; background: #fff; color: var(--n-text, #2f2f2f);
        font-family: inherit;
        transition: border-color .12s, box-shadow .12s;
    }
    .ipub-input:focus, .ipub-select:focus {
        outline: none; border-color: #2383E2; box-shadow: 0 0 0 2px rgba(35,131,226,.15);
    }
    [data-theme="dark"] .ipub-input, [data-theme="dark"] .ipub-select {
        background: #2a2a2a; border-color: #3a3a3a; color: #e0e0e0;
    }
    /* ── Custom dropdown (IPubDropdown) — popup is capped + scrollable, never overflows modal ── */
    .ipub-dd { position: relative; flex: 1; min-width: 0; }
    .ipub-dd-trigger {
        display: flex; align-items: center; justify-content: space-between;
        cursor: pointer; text-align: left; width: 100%;
        background: #fff;
    }
    .ipub-dd-trigger:disabled { opacity: .55; cursor: not-allowed; background: #f5f5f5; }
    .ipub-dd-value {
        flex: 1; min-width: 0;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .ipub-dd-value.is-placeholder { color: #9ca3af; }
    .ipub-dd-caret { color: #6b7280; font-size: .65rem; margin-left: 6px; }
    .ipub-dd.is-open .ipub-dd-caret { transform: rotate(180deg); }
    .ipub-dd-menu {
        position: absolute; top: calc(100% + 2px); left: 0; right: 0;
        max-height: 220px; overflow-y: auto;
        background: #fff; border: 1px solid #d1d5db; border-radius: 4px;
        z-index: 10000; box-shadow: 0 4px 12px rgba(0,0,0,.12);
        font-size: .76rem;
    }
    .ipub-dd-item {
        padding: 6px 10px; cursor: pointer; color: #2f2f2f;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .ipub-dd-item:hover { background: #eff6ff; }
    .ipub-dd-item.is-selected { background: #dbeafe; font-weight: 600; }
    .ipub-dd-item-placeholder { color: #9ca3af; }
    .ipub-dd-item.is-empty { color: #9ca3af; cursor: default; font-style: italic; }
    [data-theme="dark"] .ipub-dd-trigger { background: #2a2a2a; color: #e0e0e0; }
    [data-theme="dark"] .ipub-dd-menu { background: #2a2a2a; border-color: #3a3a3a; }
    [data-theme="dark"] .ipub-dd-item { color: #e0e0e0; }
    [data-theme="dark"] .ipub-dd-item:hover { background: #3a3a3a; }
    [data-theme="dark"] .ipub-dd-item.is-selected { background: #1e3a5f; }
    .ipub-checks { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
    .ipub-check { display: inline-flex; align-items: center; gap: 5px; font-size: .76rem; color: var(--n-text-2); }
    .ipub-tabs {
        display: flex; gap: 0;
        border-bottom: 1px solid var(--n-border, #d6d4cf);
        margin-bottom: 10px;
    }
    .ipub-tab {
        padding: 6px 16px; font-size: .76rem; font-weight: 600;
        color: var(--n-text-3); cursor: pointer;
        border: 1px solid transparent; border-bottom: none;
        border-radius: 5px 5px 0 0;
        margin-bottom: -1px;
        background: transparent;
    }
    .ipub-tab.active {
        color: var(--n-text, #2f2f2f);
        background: var(--n-surface, #fff);
        border-color: var(--n-border, #d6d4cf);
    }

    .n-toast-success { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
    .n-toast-success .n-toast-icon { background: #22c55e; color: #fff; }
    .n-toast-error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
    .n-toast-error .n-toast-icon { background: #ef4444; color: #fff; }
    .n-toast-info { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
    .n-toast-info .n-toast-icon { background: #3b82f6; color: #fff; }
    .n-toast-warn { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; }
    .n-toast-warn .n-toast-icon { background: #f59e0b; color: #fff; }

    [data-theme="dark"] .n-toast-success { background: #052e16; color: #86efac; border-color: #166534; }
    [data-theme="dark"] .n-toast-error { background: #450a0a; color: #fca5a5; border-color: #991b1b; }
    [data-theme="dark"] .n-toast-info { background: #172554; color: #93c5fd; border-color: #1e40af; }
    [data-theme="dark"] .n-toast-warn { background: #451a03; color: #fcd34d; border-color: #92400e; }
</style>

<div class="n-workspace @(_focusMode ? "n-focus-mode" : "")">

@* ══ Toast notification ═══════════════════════════════════════════════════ *@
@if (_toastVisible)
{
    <div class="n-toast @_toastClass" @onclick="DismissToast">
        <span class="n-toast-icon">@_toastIcon</span>
        <span class="n-toast-msg">@_toastMessage</span>
        <span class="n-toast-close">✕</span>
    </div>
}

@if (_focusMode)
{
   <button class="n-focus-exit" @onclick="ExitFocusMode" title="Exit Focus Mode (Esc)">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="15 3 21 3 21 9"/>
        <polyline points="9 21 3 21 3 15"/>
        <line x1="21" y1="3" x2="14" y2="10"/>
        <line x1="3" y1="21" x2="10" y2="14"/>
    </svg>
</button>

}

<!-- ══ Hidden header (Blazor event handlers, forwarded from ribbon-injected buttons) ══ -->
<header class="n-topbar n-topbar--hidden">
    <button id="nBtnSidebarToggle" class="n-btn n-btn-ghost n-btn-icon @(_leftPaneOpen ? "active" : "")"
            @onclick="ToggleLeftPane" title="Toggle Panel"></button>
    <button id="nBtnMeta" class="n-btn n-btn-ghost n-btn-icon"
            @onclick="OpenMetaDialog" title="iPubEdit Meta Information"></button>
    <button id="nBtnProperties" class="n-btn n-btn-ghost n-btn-icon" hidden
            @onclick="TogglePropertiesPanel" title="iPubEdit Properties (Ctrl+Alt+M)"></button>
    <button id="nBtnSearch" class="n-btn n-btn-ghost n-btn-icon @(_navPaneOpen ? "active" : "")"
            @onclick="ToggleNavigationPane" title="Find &amp; Replace (Ctrl+F)"></button>
    <button id="nBtnFocusMode" class="n-btn n-btn-ghost n-btn-icon"
            @onclick="EnterFocusMode" title="Focus Mode"></button>
    <button id="nBtnTheme" class="n-btn n-btn-ghost n-btn-icon n-theme-toggle"
            @onclick="ToggleTheme"></button>
    <button id="nBtnSave" class="n-btn1 n-btn-ghost" @onclick="SaveDocument" title="Save (Ctrl+S)"></button>
    <button id="btnSaveAs" class="n-btn1 n-btn-ghost" title="Save As (Ctrl+Shift+S)"
            data-tab-id="@(ActiveTab?.Id)" data-filename="@(ActiveTab?.FileName ?? "Untitled.docx")"></button>
    <button id="nBtnManuscript" class="n-btn n-btn-manuscript @(_manuscriptProcessing ? "processing" : "")"
            @onclick="ProcessManuscript" title="AI Manuscript Processor"
            disabled="@_manuscriptProcessing"></button>
    <button id="nBtnAiChat" class="n-btn n-btn-ai @(_chatOpen ? "active" : "")"
            @onclick="ToggleChat" title="Toggle AI Assistant"></button>
    <InputFile id="fileUploadInput" OnChange="HandleFileUpload"
         accept=".docx,.doc,.rtf,.txt,.xml" style="display:none" />
</header>

<!-- ══ Recovery Banner ═══════════════════════════════════════════════════ -->
@if (_showRecoveryBanner && _recoveryDrafts.Count > 0)
{
    <div class="n-recovery-banner">
        <span>⚠️</span>
        <span class="n-recovery-banner-text">
            <strong>Unsaved draft found</strong> — @_recoveryDrafts[0].FileName
            <span style="font-size:.7rem;opacity:.72;margin-left:4px;">(@FormatRelativeTime(_recoveryDrafts[0].SavedAt))</span>
        </span>
        <button class="n-recovery-btn n-recovery-btn-restore" @onclick="RestoreFirstDraft">↩ Restore</button>
        <button class="n-recovery-btn n-recovery-btn-dismiss" @onclick="DismissRecovery">Dismiss</button>
    </div>
}

<!-- ══ Main ══════════════════════════════════════════════════════════════ -->
<div class="n-main">

    <!-- ── Left Sidebar ──────────────────────────────────────────────── -->
    @if (_leftPaneOpen)
    {
        <aside class="n-left-sidebar">
            <div class="n-left-header">
                <div class="n-left-title"></div>
                <button class="n-left-close" @onclick="ToggleLeftPane" title="Close">✕</button>
            </div>

            <div class="n-left-tabs">
                <div class="n-left-tab @(_leftTab=="files" ? "active" : "")" @onclick='()=>_leftTab="files"'>Files</div>
                <div class="n-left-tab @(_leftTab=="schema" ? "active" : "")" @onclick='()=>_leftTab="schema"'>Schema</div>
                <div class="n-left-tab @(_leftTab=="ccprop" ? "active" : "")" @onclick="OpenCcPropertyTab">CC Property</div>
            </div>

            @if (_leftTab == "files")
            {
                <div class="n-sidebar-section">
                    <div class="n-sidebar-section-label">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" opacity=".5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                        Current File
                    </div>
                    <div class="n-file-card">
                        <div class="n-file-card-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                        </div>
                        <div class="n-file-card-info">
                            <div class="n-file-card-name" id="left-sidebar-filename">@(_currentFileName ?? "Untitled.docx")</div>
                            @if (!string.IsNullOrEmpty(_autoSaveLabel))
                            {
                                <div class="n-file-card-meta">
                                    <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    @_autoSaveLabel
                                </div>
                            }
                            else
                            {
                                <div class="n-file-card-meta">.docx</div>
                            }
                        </div>
                    </div>
                </div>

                <div class="n-sidebar-section">
                    <div class="n-sidebar-section-label">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" opacity=".5">
                            <path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>
                        </svg>
                        Document Statistics
                        <button class="n-refresh-btn" @onclick="RefreshStats">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <polyline points="23 4 23 10 17 10"/>
                                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
                            </svg>
                        </button>
                    </div>
                    <div class="n-stats-grid">
                        <div class="n-stat-card"><div class="n-stat-value">@_statWords.ToString("N0")</div><div class="n-stat-label">Words</div></div>
                        <div class="n-stat-card"><div class="n-stat-value">@_statChars.ToString("N0")</div><div class="n-stat-label">Characters</div></div>
                        <div class="n-stat-card"><div class="n-stat-value">@_statSentences.ToString("N0")</div><div class="n-stat-label">Sentences</div></div>
                        <div class="n-stat-card"><div class="n-stat-value">@_statReadMin</div><div class="n-stat-label">Min Read</div></div>
                    </div>
                    @if (_statWords > 0)
                    {
                        <div class="n-stats-footer">
                            <span>Avg sentence length</span>
                            <span class="n-stats-footer-value">@_statAvgSentLen words</span>
                        </div>
                    }
                </div>

                <div class="n-left-section">
                    <div class="n-left-section-label">Recent Files</div>
                    @if (_recentFiles.Count == 0)
                    {
                        <div style="font-size:.74rem;color:var(--n-text-3);font-style:italic;padding:4px 2px;">No recent files yet.</div>
                    }
                    else
                    {
                        @foreach (var rf in _recentFiles)
                        {
                            <div class="n-recent-item" title="@rf.Name">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;opacity:.6;">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                </svg>
                                <span class="n-recent-name">@rf.Name</span>
                                <span class="n-recent-time">@rf.TimeLabel</span>
                            </div>
                        }
                        <button class="n-left-action-btn n-left-action-btn-danger" style="margin-top:6px;" @onclick="ClearRecentFiles">
                            Clear History
                        </button>
                    }
                </div>
            }

            @if (_leftTab == "schema")
            {
                <div class="n-sidebar-section">
                    <div class="n-sidebar-section-label">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" opacity=".5">
                            <path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/>
                        </svg>
                        Content Controls
                    </div>

                    @if (_schemaFields.Count == 0 && !_schemaLoaded)
                    {
                        <div class="schema-empty-state">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                            <div>Scan document to extract tagged content controls</div>
                        </div>
                    }

                    <button class="cc-extract-btn" @onclick="ExtractSchemaFromDocument">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                        </svg>
                        Extract from Document
                        @if (_schemaFields.Count > 0)
                        {
                            <span class="cc-extract-count">@_schemaFields.Count(f => !string.IsNullOrEmpty(f.Value))</span>
                        }
                    </button>

                    @if (_schemaLoaded)
                    {
                        <div class="cc-schema-badge">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span class="cc-schema-name">@_schemaName</span>
                            <button class="cc-schema-remove" @onclick="ClearSchema" title="Remove schema">✕</button>
                        </div>
                    }

                        @if (_schemaFields.Count > 0)
                        {
                            <div class="schema-controls-scroll" style="margin-top:6px;">
                                @foreach (var group in GetSchemaGroups())
                                {
                                    var grp = group;
                                    var groupFields = _schemaFields.Where(f => f.Group == grp).ToList();
                                    var isGroupExpanded = _expandedGroups.Contains(grp);
                                    var filledCount = groupFields.Count(f => !string.IsNullOrEmpty(f.Value));

                                    <div class="cc-group">
                                        <div class="cc-group-header @(!isGroupExpanded ? "collapsed" : "")"
                                             @onclick="() => ToggleSchemaGroup(grp)">
                                            <svg class="cc-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                                <polyline points="6 9 12 15 18 9"/>
                                            </svg>
                                            @grp
                                            <span class="cc-group-count">@filledCount / @groupFields.Count</span>
                                        </div>

                                        @if (isGroupExpanded)
                                        {
                                            <div class="cc-group-body">
                                                @foreach (var field in groupFields)
                                                {
                                                    @if (field.Type == "collection" || field.Type == "sections" || (field.Children?.Count > 0))
                                                    {
                                                        <div class="cc-collection-toggle @(!field.IsExpanded ? "collapsed" : "")"
                                                             @onclick="() => ToggleFieldExpand(field)">
                                                            <svg class="cc-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                                                <polyline points="6 9 12 15 18 9"/>
                                                            </svg>
                                                            <span class="cc-type-badge @(field.Type.ToLower().Replace(" ", "-"))">@field.Type</span>
                                                            @field.Label
                                                            @if (!string.IsNullOrEmpty(field.Value))
                                                            {
                                                                <span class="cc-group-count">@field.Value</span>
                                                            }
                                                        </div>

                                                        @if (field.IsExpanded && field.Children?.Count > 0)
                                                        {
                                                            @foreach (var child in field.Children)
                                                            {
                                                                <div class="cc-child-item @(field.Type == "sections" ? "cc-section-item" : "")"
                                                                     data-depth="@child.Depth">
                                                                    @if (child.Children?.Count > 0)
                                                                    {
                                                                        <div class="cc-section-label" @onclick="() => { ToggleChildExpand(child); _ = NavigateToSchemaItem(child.Label); }">
                                                                            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                                                 stroke-width="3" style="transform:rotate(@(child.IsExpanded ? "0" : "-90")deg);transition:transform .15s;">
                                                                                <polyline points="6 9 12 15 18 9"/>
                                                                            </svg>
                                                                            @child.Label
                                                                            @if (child.Fields?.Any(f => f.Key == "id") == true)
                                                                            {
                                                                                <span class="cc-section-id">@child.Fields.First(f => f.Key == "id").Value</span>
                                                                            }
                                                                        </div>
                                                                        @if (child.IsExpanded)
                                                                        {
                                                                            @foreach (var subChild in child.Children)
                                                                            {
                                                                                <div class="cc-child-item cc-section-item" data-depth="@(subChild.Depth)">
                                                                                    <div class="cc-section-label" @onclick="() => NavigateToSchemaItem(subChild.Label)" style="cursor:pointer;">
                                                                                        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                            <circle cx="12" cy="12" r="3"/>
                                                                                        </svg>
                                                                                        @subChild.Label
                                                                                        @if (subChild.Fields?.Any(f => f.Key == "id") == true)
                                                                                        {
                                                                                            <span class="cc-section-id">@subChild.Fields.First(f => f.Key == "id").Value</span>
                                                                                        }
                                                                                    </div>
                                                                                </div>
                                                                            }
                                                                        }
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="cc-child-label" @onclick="() => NavigateToSchemaItem(child.Label)" style="cursor:pointer;">@child.Label</div>
                                                                        @if (child.Fields != null)
                                                                        {
                                                                            @foreach (var cf in child.Fields)
                                                                            {
                                                                                <div class="cc-child-field" @onclick="() => NavigateToSchemaItem(cf.Value)" style="@(!string.IsNullOrEmpty(cf.Value) ? "cursor:pointer;" : "")">
                                                                                    <span class="cc-child-field-key">@cf.Label:</span>
                                                                                    <span class="cc-child-field-val @(string.IsNullOrEmpty(cf.Value) ? "empty" : "cc-clickable")">
                                                                                        @(string.IsNullOrEmpty(cf.Value) ? "(empty)" : cf.Value)
                                                                                    </span>
                                                                                </div>
                                                                            }
                                                                        }
                                                                    }
                                                                </div>
                                                            }
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div class="cc-field">
                                                            <div class="cc-field-label">
                                                                @field.Label
                                                                @if (field.Required)
                                                                {
                                                                    <span class="cc-required">*</span>
                                                                }
                                                                <span class="cc-type-badge @(field.Type.ToLower().Replace(" ", "-"))">@field.Type</span>
                                                            </div>
                                                            <div class="cc-field-value @(string.IsNullOrEmpty(field.Value) ? "empty" : "cc-clickable") @(field.Type == "richtext" ? "richtext" : "")"
                                                                 @onclick="() => NavigateToSchemaItem(field.Value)">>
                                                                @if (string.IsNullOrEmpty(field.Value))
                                                                {
                                                                    @("(empty)")
                                                                }
                                                                else if (field.Type == "dropdown" && field.EnumValues?.Count > 0)
                                                                {
                                                                    @field.Value
                                                                    <span style="font-size:.6rem;color:var(--n-text-3);margin-left:4px;">
                                                                        (@field.EnumValues.Count options)
                                                                    </span>
                                                                }
                                                                else
                                                                {
                                                                    @field.Value
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                </div>
            }

            @if (_leftTab == "ccprop")
            {
                <div class="n-sidebar-section ccp-sidebar">
                    <div class="n-sidebar-section-label">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" opacity=".5">
                            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                            <line x1="7" y1="7" x2="7.01" y2="7"/>
                        </svg>
                        Content Control Tags
                    </div>
                    <div class="ccp-search-wrap">
                        <input type="text" class="ccp-search-input" placeholder="Search tags..."
                               @bind="_ccpSearch" @bind:event="oninput" />
                    </div>
                    <div class="ccp-tag-list">
                        @foreach (var group in GetCcpGroups())
                        {
                            var groupTags = GetCcpTagsForGroup(group);
                            if (groupTags.Any())
                            {
                                <div class="ccp-sidebar-group">@group</div>
                                @foreach (var tag in groupTags)
                                {
                                    <div class="ccp-sidebar-item" @onclick="() => ApplyTagToSelection(tag.Tag, tag.Display)" title="@tag.Display (@tag.Tag)">
                                        <span class="ccp-sidebar-tag">@tag.Tag</span>
                                        @if (tag.Display != tag.Tag)
                                        {
                                            <span class="ccp-sidebar-desc">@tag.Display</span>
                                        }
                                    </div>
                                }
                            }
                        }
                        @if (!GetCcpGroups().Any())
                        {
                            <div class="ccp-sidebar-empty">No matching tags</div>
                        }
                    </div>
                </div>
            }
        </aside>
    }

    <div class="n-editor-area">
        <button class="n-sidebar-fab @(_leftPaneOpen ? "active" : "")"
                @onclick="ToggleLeftPane" title="Toggle Panel">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/>
            </svg>
        </button>
        <div id="editorArea"></div>
    </div>

    @if (_chatOpen)
    {
        <aside class="n-ai-sidebar">
            <div class="n-ai-header">
                <div class="n-ai-title"><span class="n-ai-star">✦</span> AI Assistant</div>
                <button class="n-ai-close" @onclick="ToggleChat" title="Close">✕</button>
            </div>
            <div class="n-ai-actions">
                <button class="n-ai-processor-btn @(_manuscriptProcessing ? "processing" : "")"
                        @onclick="ProcessManuscript" disabled="@_manuscriptProcessing">
                    @if (_manuscriptProcessing)
                    {
                        <span class="n-manuscript-spinner"></span>
                        <span>Analyzing...</span>
                    }
                    else
                    {
                        <span>✦ AI Processor</span>
                    }
                </button>
            </div>
            <div class="n-ai-actions" style="border-top:none;padding-top:0;">
                <button class="n-ai-action-btn" @onclick='() => QuickAction("proofread")' disabled="@_chatLoading">Proofread</button>
                <button class="n-ai-action-btn" @onclick='() => QuickAction("copyedit")'  disabled="@_chatLoading">Copyedit</button>
            </div>
            <div class="n-ai-actions" style="border-top:none;padding-top:0;gap:4px;">
                <button class="n-ai-action-btn" @onclick='() => QuickAction("summarize")' disabled="@_chatLoading" title="1-paragraph summary">Summarize</button>
                <button class="n-ai-action-btn" @onclick='() => QuickAction("tone")'      disabled="@_chatLoading" title="Tone analysis">Tone</button>
            </div>
            <div class="n-ai-messages" id="chatMessages">
                @if (_chatMessages.Count == 0)
                {
                    <div class="n-ai-empty">
                        <div class="n-ai-empty-icon">✦</div>
                        <p>Select text and click an action, or ask me anything. Type <strong>/</strong> in the document to insert snippets.</p>
                    </div>
                }
                @foreach (var msg in _chatMessages)
                {
                    <div class="n-ai-msg n-ai-msg-@msg.Role">
                        <div class="n-ai-msg-label">@(msg.Role == "user" ? "You" : "AI")</div>
                        <div class="n-ai-msg-body">@((MarkupString)msg.HtmlContent)</div>
                        @if (msg.Role == "assistant" && !string.IsNullOrEmpty(msg.ApplicableText))
                        {
                            if (msg.HtmlContent.Contains("Original:"))
                            {
                                <button class="n-ai-apply-btn" @onclick="() => ApplySuggestion(msg.ApplicableText!)">↩ Apply to document</button>
                            }
                            else
                            {
                                <button class="n-ai-apply-btn n-ai-preview-btn" @onclick="() => PreviewSuggestion(msg)">👁 Preview</button>
                            }
                        }
                    </div>
                }
                @if (_chatLoading)
                {
                    <div class="n-ai-msg n-ai-msg-assistant">
                        <div class="n-ai-msg-label">AI</div>
                        <div class="n-ai-msg-body n-ai-typing"><span></span><span></span><span></span></div>
                    </div>
                }
            </div>
            <div class="n-ai-input-row">
                <textarea class="n-ai-input" placeholder="Ask about your document…"
                          @bind="_chatInput" @bind:event="oninput"
                          @onkeydown="HandleChatKeyDown" rows="2"
                          disabled="@_chatLoading"></textarea>
                <button class="n-ai-send" @onclick="SendChatMessage"
                        disabled="@(_chatLoading || string.IsNullOrWhiteSpace(_chatInput))">➤</button>
            </div>
        </aside>
    }

    <!-- ══ iPubEdit Properties — right-side docked panel (in-flex) ════════ -->
    <aside class="ipub-properties-panel @(_showPropertiesPanel ? "open" : "")" id="ipubPropertiesPanel" hidden="@(!_showPropertiesPanel)">
        <header class="ipp-header">
            <span>iPubEdit Properties</span>
            <button class="ipp-close" @onclick="() => _showPropertiesPanel = false" title="Close">×</button>
        </header>

        <section class="ipp-tag">
            <div class="ipp-tag-label" id="ippTagLabel">— no tag —</div>
            <div class="ipp-tag-row">
                <input id="ippTagInput" class="ipp-input" placeholder="tag name" />
                <button class="ipp-icon-btn" id="ippSearchBtn" title="Find this tag in tree">🔍</button>
            </div>
            <div class="ipp-actions">
                <button id="ippReload" type="button">Reload</button>
                <button id="ippActivate" type="button">Activate</button>
                <button id="ippRemove" type="button">Remove</button>
            </div>
            <div class="ipp-options">
                <select id="ippDefault"><option>Default</option></select>
                <label><input type="checkbox" id="ippConfirm" checked /> Confirmation</label>
            </div>
        </section>

        <section class="ipp-tree">
            <h4>Element Name</h4>
            <div id="ippTreeRoot" class="ipp-tree-root"></div>
        </section>

        <section class="ipp-attrs">
            <div class="ipp-attrs-header">
                <span>Attributes :</span>
                <span id="ippAttrTag">—</span>
                <button id="ippAttrRemove" type="button">Remove</button>
                <button id="ippAttrSave" type="button">Save</button>
            </div>
            <div class="ipp-attr-scroll">
                <table id="ippAttrTable" class="ipp-attr-grid"></table>
            </div>
        </section>

        <nav class="ipp-tabs">
            <button class="active" type="button">Element</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">References</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">Find &amp; Replace</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">FootNote / EndNote</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">Style</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">Stage-2 Process</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">Quotes Process</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">Number to MathType</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">Editing Features</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">Footnote References</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">Link</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">LaTeX Entity</button>
            <button class="ipp-tab-disabled" type="button" title="Coming soon">Clean Up</button>
        </nav>
    </aside>

</div>

<!-- ══ Sheet Tab Bar ══════════════════════════════════════════════════════ -->
<div class="n-sheet-bar">
    <button class="n-sheet-add" @onclick="NewTab" title="Add sheet">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
    </button>
    <div class="n-sheet-tabs">
        @foreach (var tab in _tabs)
        {
            <div class="n-sheet-tab @(tab.Id == _activeTabId ? "active" : "")"
                 @onclick="() => SwitchTab(tab.Id)" title="@tab.FileName">
                @if (_renamingTabId == tab.Id)
                {
                    <input class="n-sheet-rename-input"
                           @bind="_renameValue" @bind:event="oninput"
                           @onblur="CommitRename" @onkeydown="HandleRenameKey"
                           maxlength="40" @ref="_renameInputRef" />
                }
                else
                {
                    <span class="n-sheet-tab-name" @ondblclick="() => StartRename(tab)">@tab.TabLabel</span>
                    @if (tab.IsModified) { <span class="n-sheet-tab-dirty" title="Unsaved changes"></span> }
                }
                @if (_tabs.Count > 1)
                {
                    <button class="n-sheet-tab-close" @onclick:stopPropagation="true"
                            @onclick="() => CloseTab(tab.Id)" title="Close sheet">✕</button>
                }
            </div>
        }
    </div>
</div>

@if (_slashPickerVisible)
{
    <div class="n-slash-picker" id="slashPicker"
         style="left:@(_slashPickerX.ToString("F0"))px;top:@(_slashPickerY.ToString("F0"))px;">
        <div class="n-slash-header">Snippets — press Esc to close</div>
        @for (int i = 0; i < _snippets.Count; i++)
        {
            var localIdx = i;
            var s = _snippets[i];
            <div class="n-slash-item @(_slashActiveIdx == localIdx ? "n-slash-active" : "")"
                 @onclick="() => InsertSnippet(localIdx)"
                 @onmouseover="() => _slashActiveIdx = localIdx">
                <span class="n-slash-icon">@s.Icon</span>
                <div>
                    <div class="n-slash-label">@s.Label</div>
                    <div class="n-slash-desc">@s.Desc</div>
                </div>
            </div>
        }
    </div>
}

<!-- ══ File Not Found Modal ══════════════════════════════════════════════ -->
@if (_showFileNotFoundModal)
{
    <div class="n-modal-overlay" @onclick="CloseFileNotFoundModal">
        <div class="n-modal" @onclick:stopPropagation="true">
            <div class="n-modal-header">
                <h3>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#D44C47" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                    DEditor
                </h3>
                <button class="n-modal-close" @onclick="CloseFileNotFoundModal">✕</button>
            </div>
            <div class="n-modal-body">
                Cannot find the <code>@_missingFileName</code> file.
                <br/><br/>
                It may have been moved, renamed, or deleted. Would you like to save it to a new location?
            </div>
            <div class="n-modal-footer">
                <button class="n-modal-btn n-modal-btn-secondary" @onclick="CloseFileNotFoundModal">Cancel</button>
                <button class="n-modal-btn n-modal-btn-primary" @onclick="HandleFileNotFoundSaveAs">Save As</button>
            </div>
        </div>
    </div>
}
<!-- ══ Unsaved Changes Modal ═════════════════════════════════════════════ -->
@if (_showUnsavedModal)
{
    <div class="n-modal-overlay" @onclick="CancelCloseTab">
        <div class="n-modal" @onclick:stopPropagation="true">
            <div class="n-modal-header">
                <h3>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E9A23B" stroke-width="2">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    Unsaved Changes
                </h3>
                <button class="n-modal-close" @onclick="CancelCloseTab">✕</button>
            </div>
            <div class="n-modal-body">
                <strong>@_pendingCloseFileName</strong> has unsaved changes.
                <br/><br/>
                Do you want to save before closing?
            </div>
            <div class="n-modal-footer">
                <button class="n-modal-btn n-modal-btn-secondary" @onclick="CancelCloseTab">Cancel</button>
                <button class="n-modal-btn" style="background:#D44C47;color:#fff;border-color:#D44C47;" @onclick="DiscardAndCloseTab">Discard</button>
                <button class="n-modal-btn n-modal-btn-primary" @onclick="SaveAndCloseTab">Save</button>
            </div>
        </div>
    </div>
}

<!-- ══ iPubEdit Meta Information Modal ══════════════════════════════════ -->
@if (_showMetaDialog)
{
    <div class="n-modal-overlay" @onclick="CloseMetaDialog">
        <div class="ipub-modal" @onclick:stopPropagation="true">
            <div class="ipub-title">
                <span>iPubEdit Meta Information</span>
                <button class="ipub-close" @onclick="CloseMetaDialog" title="Close">✕</button>
            </div>
            <div class="ipub-toolbar">
                <button class="ipub-save-btn" @onclick="SaveMetadata" title="Save">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                        <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
                    </svg>
                    Save
                </button>
            </div>
            <div class="ipub-body">
                <!-- Header section -->
                <div class="ipub-row ipub-row-4">
                    <div class="ipub-field @(_metaErrors.ContainsKey("Publisher") ? "ipub-invalid" : "")">
                        <label class="ipub-label">Publisher Name<span class="req">*</span></label>
                        <SfDropDownList TValue="string" TItem="string"
                                        DataSource="@_publisherNames"
                                        Value="@_meta.Publisher"
                                        Placeholder="Select an option"
                                        AllowFiltering="true"
                                        FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains">
