            {
                var json = await JSRuntime.InvokeAsync<string>("eval", "JSON.stringify(getCCTagDB())");
                var tags = System.Text.Json.JsonSerializer.Deserialize<List<CcTagDto>>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
                _ccpTags = tags.Select(t => new CcTag(t.t ?? "", t.d ?? t.t ?? "", t.g ?? "")).ToList();
                _ccpTagsLoaded = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[CCProp] Failed to load tags: {ex.Message}");
