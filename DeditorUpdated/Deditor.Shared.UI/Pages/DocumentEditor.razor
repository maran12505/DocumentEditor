    // Copyedit / Pre-Editing are mutually exclusive — checking one auto-clears the other.
    // If both end up unchecked, CE Template + Book ID are hidden by the markup, and we
    // also clear their values so a stale save doesn't leak.
    private void OnCopyeditChanged(ChangeEventArgs e)
    {
        var on = e.Value is bool b && b;
        _meta.Copyedit = on;
        if (on) _meta.PreEditing = false;
        if (!_meta.Copyedit && !_meta.PreEditing)
        {
            _meta.CeTemplate = "";
            _meta.BookOrJournalId = "";
        }
        StateHasChanged();
    }

    private void OnPreEditingChanged(ChangeEventArgs e)
    {
        var on = e.Value is bool b && b;
        _meta.PreEditing = on;
        if (on) _meta.Copyedit = false;
        if (!_meta.Copyedit && !_meta.PreEditing)
        {
            _meta.CeTemplate = "";
