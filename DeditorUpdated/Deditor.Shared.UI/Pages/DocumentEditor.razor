    private void CommitRename() { var tab = _tabs.FirstOrDefault(t => t.Id == _renamingTabId); if (tab != null && !string.IsNullOrWhiteSpace(_renameValue)) { var ext = System.IO.Path.GetExtension(tab.FileName); tab.FileName = _renameValue.Trim() + (string.IsNullOrEmpty(ext) ? ".docx" : ext); } _renamingTabId = Guid.Empty; StateHasChanged(); }
