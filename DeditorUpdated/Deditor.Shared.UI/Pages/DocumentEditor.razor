    private record CcTagDto(string? t, string? d, string? g);

    private IEnumerable<string> GetCcpGroups()
    {
        var filter = (_ccpSearch ?? "").ToLower();
        return _ccpTags
            .Where(t => string.IsNullOrEmpty(filter) || t.Tag.ToLower().Contains(filter) || t.Display.ToLower().Contains(filter))
            .Select(t => t.Group)
            .Distinct()
            .OrderBy(g => g);
    }

    private IEnumerable<CcTag> GetCcpTagsForGroup(string group)
    {
        var filter = (_ccpSearch ?? "").ToLower();
        return _ccpTags
            .Where(t => t.Group == group && (string.IsNullOrEmpty(filter) || t.Tag.ToLower().Contains(filter) || t.Display.ToLower().Contains(filter)));
    }

