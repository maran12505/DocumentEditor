    private static string FormatRelativeTime(string? iso)
    {
        if (string.IsNullOrEmpty(iso) || !DateTime.TryParse(iso, out var dt)) return "recently";
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 1) return "just now"; if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago"; return dt.ToString("MMM d");
    }

