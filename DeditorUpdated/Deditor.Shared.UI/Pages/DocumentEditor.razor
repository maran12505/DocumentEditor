                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">Document Type</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@_documentTypes"
                                                @bind-Value="_meta.DocumentType"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="ipub-section">
                        <div class="ipub-section-title">Book Information</div>
                        <div class="ipub-row">
                            <div class="ipub-field">
                                <label class="ipub-label">DTD</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@_knownDtdOptions"
                                                @bind-Value="_meta.Dtd"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">Pagination Platform</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@(new[] { "ThreeB2", "InDesign", "LaTeX" })"
                                                @bind-Value="_meta.PaginationPlatform"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">Country</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@(new[] { "None", "US", "UK", "IN" })"
                                                @bind-Value="_meta.Country"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                        </div>
                        <div class="ipub-row" style="grid-template-columns:1fr;">
                            <div class="ipub-field">
                                <label class="ipub-label">Book Title</label>
                                <SfTextBox @bind-Value="_meta.BookTitle" Placeholder="Enter book title" />
                            </div>
                        </div>
                        <div class="ipub-row">
                            <div class="ipub-field @(_metaErrors.ContainsKey("Isbn") ? "ipub-invalid" : "")">
                                <label class="ipub-label">ISBN</label>
                                <SfTextBox @bind-Value="_meta.Isbn" Placeholder="10 or 13 digits" />
                                @if (_metaErrors.TryGetValue("Isbn", out var eIsbn)) { <span class="ipub-err">@eIsbn</span> }
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">Month</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@_months"
                                                @bind-Value="_meta.Month"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                            <div class="ipub-field @(_metaErrors.ContainsKey("Year") ? "ipub-invalid" : "")">
                                <label class="ipub-label">Year</label>
                                <SfTextBox @bind-Value="_meta.Year" Placeholder="YYYY" />
                                @if (_metaErrors.TryGetValue("Year", out var eYr)) { <span class="ipub-err">@eYr</span> }
                            </div>
                        </div>
                        <div class="ipub-row">
                            <div class="ipub-field">
                                <label class="ipub-label">Language</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@_languages"
                                                @bind-Value="_meta.Language"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">Process Type</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@(new[] { "Book", "Chapter" })"
                                                @bind-Value="_meta.ProcessType"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                            <div class="ipub-field @(_metaErrors.ContainsKey("Doi") ? "ipub-invalid" : "")">
                                <label class="ipub-label">DOI</label>
                                <SfTextBox @bind-Value="_meta.Doi" Placeholder="10.xxxx/xxxxx" />
                                @if (_metaErrors.TryGetValue("Doi", out var eDoiB)) { <span class="ipub-err">@eDoiB</span> }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
