    private async Task HandleSchemaUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var xsdText = await reader.ReadToEndAsync();

            var jsonResult = await JSRuntime.InvokeAsync<string>("parseXsdSchema", xsdText);
            _schemaFields = System.Text.Json.JsonSerializer.Deserialize<List<SchemaField>>(jsonResult,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();

            _schemaLoaded = true;
            _schemaName = file.Name;
            _xmlFileName = "";
            SetStatus($"✅ Schema loaded: {file.Name}", false);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            SetStatus($"❌ Schema error: {ex.Message}", true);
        }
    }

    private async Task HandleXmlForSchema(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var xmlText = await reader.ReadToEndAsync();

            var jsonResult = await JSRuntime.InvokeAsync<string>("parseXmlForSchema", xmlText);
            _schemaFields = System.Text.Json.JsonSerializer.Deserialize<List<SchemaField>>(jsonResult,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();

            _xmlFileName = file.Name;
            SetStatus($"✅ XML loaded: {file.Name}", false);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            SetStatus($"❌ XML parse error: {ex.Message}", true);
        }
    }

