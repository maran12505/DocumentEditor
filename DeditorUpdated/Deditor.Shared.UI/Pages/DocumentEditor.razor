                    <div class="ipub-field">
                        <label class="ipub-label">XML Type</label>
                        <SfDropDownList TValue="string" TItem="string"
                                        DataSource="@(new[] { "Book", "Journal" })"
                                        Value="@_meta.XmlType"
                                        Placeholder="Select an option"
                                        AllowFiltering="true"
                                        Readonly="true"
                                        FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains">
                            <DropDownListEvents TValue="string" TItem="string"
                                                ValueChange="OnXmlTypeSfChanged" />
                        </SfDropDownList>
                    </div>
                    <div class="ipub-field">
                        <label class="ipub-label">Job Card</label>
                        <SfTextBox @bind-Value="_meta.JobCard" Placeholder="0" />
                    </div>
                </div>
                <div class="ipub-row" style="margin-bottom:10px;">
                    <div class="ipub-field ipub-checks-field">
                        <SfCheckBox TChecked="bool" Label="Copyedit"
                                    Checked="@_meta.Copyedit"
                                    ValueChange="OnCopyeditSfChanged" />
                        <SfCheckBox TChecked="bool" Label="Pre-Editing"
                                    Checked="@_meta.PreEditing"
                                    ValueChange="OnPreEditingSfChanged" />
                    </div>
                </div>

                @if (_meta.Copyedit || _meta.PreEditing)
                {
                    <div class="ipub-row ipub-row-2" style="margin-bottom:10px;">
                        <div class="ipub-field">
                            <label class="ipub-label">CE Template</label>
                            <SfDropDownList TValue="string" TItem="string"
                                            DataSource="@_ceTemplateOptions"
                                            Value="@_meta.CeTemplate"
                                            Placeholder="Select an option"
                                            AllowFiltering="true"
                                            FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                            Enabled="@(_ceTemplateOptions.Count > 0)">
                                <DropDownListEvents TValue="string" TItem="string"
                                                    ValueChange="OnCeTemplateSfChanged" />
                            </SfDropDownList>
                        </div>
                        <div class="ipub-field">
                            <label class="ipub-label">Book ID</label>
                            <SfTextBox @bind-Value="_meta.BookOrJournalId"
                                       Placeholder="Auto-filled from CE Template" />
                        </div>
                    </div>
                }

                <!-- Tab switcher -->
                <div class="ipub-tabs">
                    <div class="ipub-tab active">@(_meta.XmlType == "Journal" ? "Journal" : "Book")</div>
                </div>

                @if (_meta.XmlType == "Journal")
                {
                    <div class="ipub-section">
                        <div class="ipub-section-title">Journal Information</div>
                        <div class="ipub-row">
                            <div class="ipub-field @(_metaErrors.ContainsKey("JournalName") ? "ipub-invalid" : "")">
                                <label class="ipub-label">Journal Name<span class="req">*</span></label>
                                <SfTextBox @bind-Value="_meta.JournalName" Placeholder="Enter journal name" />
                                @if (_metaErrors.TryGetValue("JournalName", out var eJN)) { <span class="ipub-err">@eJN</span> }
                            </div>
                            <div class="ipub-field @(_metaErrors.ContainsKey("Dtd") ? "ipub-invalid" : "")">
                                <label class="ipub-label">DTD<span class="req">*</span></label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@_knownDtdOptions"
                                                @bind-Value="_meta.Dtd"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                                @if (_metaErrors.TryGetValue("Dtd", out var eDtd)) { <span class="ipub-err">@eDtd</span> }
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">Country</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@(new[] { "None", "US", "UK", "IN" })"
                                                @bind-Value="_meta.Country"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                        </div>
                        <div class="ipub-row ipub-field-full" style="grid-template-columns:1fr;">
                            <div class="ipub-field @(_metaErrors.ContainsKey("JournalTitle") ? "ipub-invalid" : "")">
                                <label class="ipub-label">Journal Title<span class="req">*</span></label>
                                <SfTextBox @bind-Value="_meta.JournalTitle" Placeholder="Enter journal title" />
                                @if (_metaErrors.TryGetValue("JournalTitle", out var eJT)) { <span class="ipub-err">@eJT</span> }
                            </div>
                        </div>
                        <div class="ipub-row">
                            <div class="ipub-field @(_metaErrors.ContainsKey("PIssn") ? "ipub-invalid" : "")">
                                <label class="ipub-label">P-ISSN<span class="req">*</span></label>
                                <SfTextBox @bind-Value="_meta.PIssn" Placeholder="e.g. 1234-5678" />
                                @if (_metaErrors.TryGetValue("PIssn", out var ePI)) { <span class="ipub-err">@ePI</span> }
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">E-ISSN</label>
                                <SfTextBox @bind-Value="_meta.EIssn" Placeholder="e.g. 1234-5678" />
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">Pagination Platform</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@(new[] { "ThreeB2", "InDesign", "LaTeX" })"
                                                @bind-Value="_meta.PaginationPlatform"
                                                Placeholder="Select an option"
                                                AllowFiltering="true"
                                                FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" />
                            </div>
                        </div>
                        <div class="ipub-row">
                            <div class="ipub-field">
                                <label class="ipub-label">Copyrights</label>
                                <SfTextBox @bind-Value="_meta.Copyrights" Placeholder="© Year, Holder" />
                            </div>
                            <div class="ipub-field @(_metaErrors.ContainsKey("PublisherImprint") ? "ipub-invalid" : "")">
                                <label class="ipub-label">Publisher Imprint<span class="req">*</span></label>
                                <SfTextBox @bind-Value="_meta.PublisherImprint" Placeholder="Imprint name" />
                                @if (_metaErrors.TryGetValue("PublisherImprint", out var ePImp)) { <span class="ipub-err">@ePImp</span> }
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">Article ID</label>
                                <SfTextBox @bind-Value="_meta.ArticleId" Placeholder="Article identifier" />
                            </div>
                        </div>
                        <div class="ipub-row">
                            <div class="ipub-field @(_metaErrors.ContainsKey("Doi") ? "ipub-invalid" : "")">
                                <label class="ipub-label">DOI</label>
                                <SfTextBox @bind-Value="_meta.Doi" Placeholder="10.xxxx/xxxxx" />
                                @if (_metaErrors.TryGetValue("Doi", out var eDoiJ)) { <span class="ipub-err">@eDoiJ</span> }
                            </div>
                            <div class="ipub-field">
                                <label class="ipub-label">Article Type</label>
                                <SfDropDownList TValue="string" TItem="string"
                                                DataSource="@(new[] { "Article", "Un-Article" })"
