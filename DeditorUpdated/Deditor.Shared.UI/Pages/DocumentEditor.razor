    [JSInvokable]
    public async Task OnFileOpenedFromJS(string fileName)
    {
        if (ActiveTab == null) return;
        var tabId = ActiveTab.Id;

        ActiveTab.FileName = fileName;
        ActiveTab.IsEmpty = false;
        ActiveTab.IsModified = false;

        // New file in this tab → drop stale metadata cached under the same tabId
        // (both the in-memory cache and the per-tab localStorage entry).
        _metaByTab.Remove(tabId);
        _metaLoadedTabs.Remove(tabId);
        _meta = new IPubEditMeta();
        try { await JSRuntime.InvokeVoidAsync("deleteIPubEditMeta", tabId.ToString()); } catch { }

        StateHasChanged();
        await LoadMetadataForActiveTabAsync();
        StateHasChanged();
    }
