        }
        StateHasChanged();
    }

    // Publisher switcher — auto-derives XML Type (Book / Journal) from the chosen
    // publisher's mapping. Reuses OnXmlTypeChanged's clearing logic so stale
    // Book-only / Journal-only fields don't leak across the form switch.
    private async Task OnPublisherChanged(ChangeEventArgs e)
    {
        var newPublisher = e.Value?.ToString() ?? "";
        if (newPublisher == _meta.Publisher) return;
        _meta.Publisher = newPublisher;
        _metaErrors.Clear();

        // CE Template list is publisher-scoped — drop stale selection + Book ID.
        _meta.CeTemplate = "";
        _meta.BookOrJournalId = "";
        await RefreshCeTemplatesAsync();

        var match = _publishers.FirstOrDefault(p =>
            string.Equals(p.Name, newPublisher, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrEmpty(match.Name) && match.Type != _meta.XmlType)
        {
            // Reuse the same form-clearing path the manual XML Type switch uses.
            // OnXmlTypeChanged also applies the DTD default for the resolved type.
            OnXmlTypeChanged(new ChangeEventArgs { Value = match.Type });
            return;
        }
        // Same publisher *type* as before — apply the DTD default for this type.
        // (Picked on publisher change so the user can still override DTD afterward.)
        ApplyDefaultDtdForType(_meta.XmlType);
        StateHasChanged();
    }

    // Auto-pick the conventional DTD for a given XML Type. User can override
    // manually after this fires — we only set, never lock.
    //   Book    → BITS
    //   Journal → JATS
    private void ApplyDefaultDtdForType(string xmlType)
    {
        _meta.Dtd = xmlType == "Book" ? "BITS" : "JATS";
    }

    // XML Type switcher — swaps the form shape and clears fields that don't belong
    // to the new type so stale Book values don't leak into a Journal save (and vice versa).
    private void OnXmlTypeChanged(ChangeEventArgs e)
    {
        var newType = e.Value?.ToString() ?? "Book";
        if (newType == _meta.XmlType) return;
        _meta.XmlType = newType;
        _metaErrors.Clear();
        // Auto-pick the conventional DTD whenever XML Type flips. User can
        // still change it manually after the auto-fill.
        ApplyDefaultDtdForType(newType);
        if (newType == "Book")
        {
            // Clear Journal-only fields (Article Type + Document Type are Journal-only now;
            // Book uses Language + Process Type instead).
            _meta.JournalName = "";
            _meta.JournalTitle = "";
            _meta.PIssn = "";
            _meta.EIssn = "";
            _meta.Copyrights = "";
            _meta.PublisherImprint = "";
            _meta.ArticleId = "";
            _meta.ArticleType = "";
            _meta.DocumentType = "";
            if (string.IsNullOrEmpty(_meta.Country)) _meta.Country = "None";
            if (string.IsNullOrEmpty(_meta.ProcessType)) _meta.ProcessType = "Book";
        }
        else // Journal
        {
            // Clear Book-only fields
            _meta.BookTitle = "";
            _meta.Isbn = "";
            _meta.Month = "";
            _meta.Year = "";
            _meta.Language = "";
            _meta.ProcessType = "Book"; // keep model default
        }
        StateHasChanged();
    }

