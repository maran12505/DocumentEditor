    private static bool IsSimpleCheck(string input) { var l = input.ToLower(); return l.Contains("word count") || l.Contains("how many words") || l.Contains("sentence count") || l.Contains("how long") || l.Contains("character count"); }

    private async Task RunFreeCheck(string query)
    {
        var text = await JSRuntime.InvokeAsync<string>("getDocumentText"); var lower = query.ToLower(); string reply;
        if (lower.Contains("word")) { var c = string.IsNullOrWhiteSpace(text) ? 0 : text.Split(new[]{' ','\n','\r','\t'}, StringSplitOptions.RemoveEmptyEntries).Length; reply = $"📊 Word count: <strong>{c:N0}</strong> words"; }
        else if (lower.Contains("sentence")) { var c = string.IsNullOrWhiteSpace(text) ? 0 : text.Split(new[]{'.','!','?'}, StringSplitOptions.RemoveEmptyEntries).Length; reply = $"📊 Sentence count: <strong>{c:N0}</strong> sentences"; }
        else if (lower.Contains("character")) reply = $"📊 Character count: <strong>{text?.Length ?? 0:N0}</strong> characters";
        else reply = "I can answer word count, sentence count, and character count for free. For other questions I'll use the AI engine.";
        AddMessage("assistant", reply, null);
    }

