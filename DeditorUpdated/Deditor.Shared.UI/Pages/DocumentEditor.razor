    private async Task RefreshStats()
    {
        var text = await JSRuntime.InvokeAsync<string>("getDocumentText");
        if (string.IsNullOrWhiteSpace(text)) { _statWords = _statChars = _statSentences = 0; _statReadMin = "0"; _statAvgSentLen = "0"; StateHasChanged(); return; }
        var words = text.Split(new[]{' ','\n','\r','\t'}, StringSplitOptions.RemoveEmptyEntries);
        var sentences = text.Split(new[]{'.','!','?'}, StringSplitOptions.RemoveEmptyEntries);
        _statWords = words.Length; _statChars = text.Length; _statSentences = sentences.Length;
        _statReadMin = Math.Max(1, _statWords / 200).ToString();
        _statAvgSentLen = _statSentences > 0 ? Math.Round((double)_statWords / _statSentences, 1).ToString("0.0") : "0";
        StateHasChanged();
    }

