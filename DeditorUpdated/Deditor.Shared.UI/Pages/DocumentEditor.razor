    private async Task ExtractSchemaFromDocument()
    {
        try
        {
            SetStatus("⏳ Extracting…", false);
            var jsonResult = await JSRuntime.InvokeAsync<string>("extractDocContentForSchema");
            if (jsonResult != "[]")
            {
                _schemaFields = System.Text.Json.JsonSerializer.Deserialize<List<SchemaField>>(jsonResult,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
                var filled = _schemaFields.Count(f => !string.IsNullOrEmpty(f.Value));
                // Cache for this tab
                _tabSchemaCache[_activeTabId] = _schemaFields.Select(f => CloneSchemaField(f)).ToList();
                SetStatus($"✅ Extracted {filled} field(s) from document.", false);
            }
            else
            {
                SetStatus("⚠️ No content controls found in document.", true);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            SetStatus($"❌ Extraction error: {ex.Message}", true);
        }
    }

