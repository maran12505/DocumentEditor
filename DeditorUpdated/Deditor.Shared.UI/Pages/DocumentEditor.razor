    // ── Document-aware load: pulls metadata for the active tab from JS/localStorage ──
    private async Task LoadMetadataForActiveTabAsync()
    {
        if (ActiveTab == null) return;
        var tabId = ActiveTab.Id;
        if (_metaByTab.TryGetValue(tabId, out var cached))
        {
            _meta = cached;
            ApplyDateDefaults(_meta);
            await RefreshCeTemplatesAsync();
            return;
        }
        try
        {
            var saved = await JSRuntime.InvokeAsync<IPubEditMeta?>("loadIPubEditMeta", tabId.ToString());
            _meta = saved ?? new IPubEditMeta();
            ApplyDateDefaults(_meta);
            _metaByTab[tabId] = _meta;
            _metaLoadedTabs.Add(tabId);
            if (saved != null)
            {
                // Auto-apply to editor so existing tokens get filled on open
                try { await JSRuntime.InvokeVoidAsync("applyMetadata", _meta); } catch { }
            }
        }
        catch
        {
            _meta = new IPubEditMeta();
        }
        await RefreshCeTemplatesAsync();
    }

    // Pre-fills Month + Year from the system clock when they're empty. Doesn't
    // touch values the user (or a previous save) already set.
    private static void ApplyDateDefaults(IPubEditMeta m)
    {
        var now = DateTime.Now;
        if (string.IsNullOrWhiteSpace(m.Month))
            m.Month = now.ToString("MMMM", System.Globalization.CultureInfo.InvariantCulture);
        if (string.IsNullOrWhiteSpace(m.Year))
            m.Year = now.Year.ToString();
    }

    // Pulls CE Template list for the current publisher from window.IPUB_CE_TEMPLATES
    // via the ipubGetCeTemplates helper (handles UI-label -> Excel-sheet-key mapping
    // for "Brill-Book" -> "BrillBook"). Empty list disables the dropdown.
    private async Task RefreshCeTemplatesAsync()
    {
        if (string.IsNullOrEmpty(_meta.Publisher))
        {
            _ceTemplateOptions = new();
            return;
        }
        try
        {
            var list = await JSRuntime.InvokeAsync<string[]?>("ipubGetCeTemplates", _meta.Publisher);
            _ceTemplateOptions = list?.ToList() ?? new();
        }
        catch
        {
            _ceTemplateOptions = new();
        }
        // If the saved CeTemplate isn't valid for the current publisher, drop it.
        if (!string.IsNullOrEmpty(_meta.CeTemplate) && !_ceTemplateOptions.Contains(_meta.CeTemplate))
        {
            _meta.CeTemplate = "";
        }
    }

