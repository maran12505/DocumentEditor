    private static string Truncate(string s, int max) => s.Length <= max ? s : s[..max] + "…";
    private static string TrimToWordLimit(string text, int maxWords) { var w = text.Split(' '); return w.Length <= maxWords ? text : string.Join(' ', w[..maxWords]); }
    private static string FormatAsHtml(string text) { var html = System.Web.HttpUtility.HtmlEncode(text); html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>"); html = System.Text.RegularExpressions.Regex.Replace(html, @"\*(.+?)\*", "<em>$1</em>"); return html.Replace("\n","<br/>"); }
    private static string? ExtractImprovedText(string r) { foreach (var p in new[]{"improved version:","revised version:","copyedited version:","here is the"}) { var idx = r.ToLower().IndexOf(p); if (idx < 0) continue; var after = r[(idx + p.Length)..].Trim().TrimStart('\n','\r',':').Trim(); var end = after.IndexOf('\n'); return end > 0 ? after[..end].Trim() : after.Trim(); } return null; }
    private void SetStatus(string msg, bool isError)
    {
        _statusMessage = msg; _statusClass = isError ? "n-status-error" : "n-status-ok";
        ShowToast(msg, isError);
    }

    private void ShowToast(string msg, bool isError)
    {
        _toastCts?.Cancel();
        _toastMessage = msg.Replace("✅ ", "").Replace("❌ ", "").Replace("⏳ ", "").Replace("⚠️ ", "");
        _toastClass = isError ? "n-toast-error" : "n-toast-success";
        _toastIcon = isError ? "✕" : "✓";
        if (msg.Contains("⏳")) { _toastClass = "n-toast-info"; _toastIcon = "⏳"; }
        else if (msg.Contains("⚠️")) { _toastClass = "n-toast-warn"; _toastIcon = "!"; }
        _toastVisible = true;
        StateHasChanged();

        _toastCts = new System.Threading.CancellationTokenSource();
        var token = _toastCts.Token;
        _ = Task.Delay(3000, token).ContinueWith(_ => InvokeAsync(() => { _toastVisible = false; StateHasChanged(); }), TaskContinuationOptions.OnlyOnRanToCompletion);
    }

    private void DismissToast() { _toastCts?.Cancel(); _toastVisible = false; StateHasChanged(); }
