    private SchemaField CloneSchemaField(SchemaField f)
    {
        return new SchemaField
        {
            Xpath = f.Xpath, Label = f.Label, Type = f.Type, Group = f.Group,
            Required = f.Required, Value = f.Value, IsExpanded = f.IsExpanded,
            EnumValues = f.EnumValues?.ToList() ?? new(),
            Children = f.Children?.Select(c => new SchemaChild
            {
                Label = c.Label, Depth = c.Depth, IsExpanded = c.IsExpanded,
                Fields = c.Fields?.Select(cf => new SchemaChildField { Key = cf.Key, Label = cf.Label, Value = cf.Value }).ToList() ?? new(),
                Children = c.Children?.ToList() ?? new()
            }).ToList() ?? new()
        };
    }

