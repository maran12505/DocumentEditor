    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Set server base URL for JS fetch calls (empty for Web, "http://localhost:5278" for MAUI)
            await JSRuntime.InvokeVoidAsync("setServerBaseUrl", AppConfig.ServerBaseUrl);
            await JSRuntime.InvokeVoidAsync("initializeDocumentEditor", _activeTabId.ToString());
            var savedTheme = await JSRuntime.InvokeAsync<string>("getThemePreference");
            if (savedTheme == "dark")
            {
                _isDarkMode = true;
                await JSRuntime.InvokeVoidAsync("applyTheme", true);
                StateHasChanged();
            }
            _selfRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerAutoSaveListener", _selfRef);
            await JSRuntime.InvokeVoidAsync("registerEditorKeyListeners", _selfRef);
            await CheckForRecoveryDrafts();
            await StartAutoSaveForActiveTab();
            await LoadRecentFiles();
        }
        await JSRuntime.InvokeVoidAsync("setDocumentName", _currentFileName ?? "Untitled.docx");

        // Sync injected ribbon header button states (safe — may not exist yet on first render)
        try
        {
            await JSRuntime.InvokeVoidAsync("syncRibbonHeader", new
            {
                isDark = _isDarkMode,
                navPaneOpen = _navPaneOpen,
                chatOpen = _chatOpen,
                leftPaneOpen = _leftPaneOpen,
                manuscriptProcessing = _manuscriptProcessing
            });
        }
        catch (JSException) { /* syncRibbonHeader not available yet */ }
    }

