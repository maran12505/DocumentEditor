    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File; if (file == null) return;
      var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (ext is not (".docx" or ".doc" or ".rtf" or ".txt" or ".xml" or ".sfdt"))
        {
            await JSRuntime.InvokeVoidAsync("eval",
                "alert('Unsupported file format: \"" + ext + "\"\\n\\nSupported formats:\\n• .docx (Word Document)\\n• .doc (Word 97-2003)\\n• .rtf (Rich Text Format)\\n• .txt (Plain Text)\\n• .sfdt (Syncfusion Document)')");
            return;
        }
        SetStatus("⏳ Opening document…", false);
        try
        {
            // Buffer once so we can feed the same bytes to import + customXml extract
            using var buf = new MemoryStream();
            using (var stream = file.OpenReadStream(maxAllowedSize: 104_857_600))
            {
                await stream.CopyToAsync(buf);
            }
            buf.Position = 0;

            var sfdt = await DocumentService.ImportAsync(buf, file.Name, buf.Length);
            var fileName = file.Name; // Keep original name and extension
            var activeTab = ActiveTab; DocTab targetTab;
            if (activeTab != null && activeTab.IsEmpty) { targetTab = activeTab; }
            else { targetTab = new DocTab { FileName = "loading", IsEmpty = false }; _tabs.Add(targetTab); _activeTabId = targetTab.Id; await JSRuntime.InvokeVoidAsync("createEditorForTab", targetTab.Id.ToString()); }
            targetTab.FileName = fileName; targetTab.IsModified = false; targetTab.IsEmpty = false;
            await JSRuntime.InvokeVoidAsync("storeSfdtToDb", targetTab.Id.ToString(), sfdt);
            // File opened via upload — no file handle, so first Save will trigger Save As
            await JSRuntime.InvokeVoidAsync("clearFileHandle", targetTab.Id.ToString());
            await JSRuntime.InvokeVoidAsync("loadDocument", sfdt);
            await StartAutoSaveForActiveTab(); await PushRecentFile(fileName);
            SetStatus($"✅ Opened: {file.Name}", false); StateHasChanged();

            // Best-effort: pull iPubEdit metadata from customXml. Errors swallowed.
            Console.WriteLine($"[HandleFileUpload] customXml-extract gate: ext={ext}");
            if (ext == ".docx")
            {
                Console.WriteLine($"[HandleFileUpload] Calling ExtractIPubMetaAsync (buffer={buf.Length} bytes, tab={targetTab.Id})");
                try
                {
                    buf.Position = 0;
                    var dto = await DocumentService.ExtractIPubMetaAsync(buf);
                    Console.WriteLine($"[HandleFileUpload] ExtractIPubMetaAsync returned: {(dto == null ? "null" : "DTO")}");
                    if (dto != null)
                    {
                        Console.WriteLine($"[HandleFileUpload] DTO summary: Publisher='{dto.Publisher}' BookTitle='{dto.BookTitle}' Isbn='{dto.Isbn}' Doi='{dto.Doi}' JournalName='{dto.JournalName}'");
                        await ApplyExtractedMetaAsync(targetTab, dto);
                    }
                    else
                    {
                        Console.WriteLine("[HandleFileUpload] No metadata DTO — skipping apply step.");
                    }
                }
                catch (Exception metaEx)
                {
                    Console.WriteLine($"[HandleFileUpload] [ExtractMeta] EXCEPTION: {metaEx.GetType().Name}: {metaEx.Message}");
                }
            }
            else
            {
                Console.WriteLine($"[HandleFileUpload] Skipping customXml extraction (ext != .docx)");
            }
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // Merges customXml-extracted metadata into the tab's IPubEditMeta only if
    // the user hasn't already saved metadata for that tab. Persists via the
    // existing JS localStorage helpers and applies tokens to the editor.
    // Mirrors of the inlined SfDropDownList option lists — used only to warn
    // when an extracted customXml value cannot be displayed by the dropdown.
    private static readonly string[] _knownDtdOptions             = { "DocBook", "BITS", "JATS", "DG-BITS" };
    private static readonly string[] _knownCountryOptions         = { "None", "US", "UK", "IN" };
    private static readonly string[] _knownPaginationPlatformOptions = { "ThreeB2", "InDesign", "LaTeX" };
    private static readonly string[] _knownProcessTypeOptions     = { "Book", "Chapter" };
    private static readonly string[] _knownXmlTypeOptions         = { "Book", "Journal" };
    private static readonly string[] _knownArticleTypeOptions     = { "Article", "Un-Article" };

    private static void WarnIfUnmatchedDropdownValue(string field, string? value, IEnumerable<string> options)
    {
        if (string.IsNullOrEmpty(value)) return;
        var arr = options as string[] ?? options.ToArray();
        if (arr.Any(o => string.Equals(o, value, StringComparison.OrdinalIgnoreCase))) return;
        var preview = string.Join(", ", arr.Take(6));
        var more = arr.Length > 6 ? ", ..." : "";
        Console.WriteLine($"[ApplyExtractedMeta] [unmatched-option] {field}='{value}' not in known options [{preview}{more}]");
    }

    private async Task ApplyExtractedMetaAsync(DocTab tab, IPubMetaDto dto)
    {
        Console.WriteLine($"[ApplyExtractedMeta] ===== START tab={tab.Id} =====");
        try
        {
            Console.WriteLine($"[ApplyExtractedMeta] Checking localStorage for existing meta on tab {tab.Id}...");
            var existing = await JSRuntime.InvokeAsync<IPubEditMeta?>("loadIPubEditMeta", tab.Id.ToString());
            if (existing != null)
            {
                Console.WriteLine($"[ApplyExtractedMeta] Existing user-saved meta found (Publisher='{existing.Publisher}'). Skipping auto-fill to preserve user edits.");
                Console.WriteLine("[ApplyExtractedMeta] ===== END (skipped) =====");
                return;
            }
            Console.WriteLine("[ApplyExtractedMeta] No existing meta — proceeding to merge DTO.");

            var meta = new IPubEditMeta();
            MergeDtoIntoMeta(dto, meta);
            ApplyDateDefaults(meta);
            Console.WriteLine($"[ApplyExtractedMeta] Merged meta: Publisher='{meta.Publisher}' BookTitle='{meta.BookTitle}' Isbn='{meta.Isbn}' Doi='{meta.Doi}' JournalName='{meta.JournalName}' Year='{meta.Year}' Month='{meta.Month}'");

            // Warn when extracted customXml values don't match any known dropdown option.
            // The model still holds the value; only the dropdown UI can't display it.
            WarnIfUnmatchedDropdownValue("Dtd",                meta.Dtd,                _knownDtdOptions);
            WarnIfUnmatchedDropdownValue("Country",            meta.Country,            _knownCountryOptions);
            WarnIfUnmatchedDropdownValue("PaginationPlatform", meta.PaginationPlatform, _knownPaginationPlatformOptions);
            WarnIfUnmatchedDropdownValue("ProcessType",        meta.ProcessType,        _knownProcessTypeOptions);
            WarnIfUnmatchedDropdownValue("XmlType",            meta.XmlType,            _knownXmlTypeOptions);
            WarnIfUnmatchedDropdownValue("ArticleType",        meta.ArticleType,        _knownArticleTypeOptions);
            WarnIfUnmatchedDropdownValue("Language",           meta.Language,           _languages);
            WarnIfUnmatchedDropdownValue("Month",              meta.Month,              _months);
            WarnIfUnmatchedDropdownValue("DocumentType",       meta.DocumentType,       _documentTypes);
            WarnIfUnmatchedDropdownValue("Publisher",          meta.Publisher,          _publisherNames);
            // CeTemplate options are loaded async per publisher (RefreshCeTemplatesAsync
            // fires below) — warn check is deferred to after that call.

            _metaByTab[tab.Id] = meta;
            _metaLoadedTabs.Add(tab.Id);
            if (tab.Id == _activeTabId)
            {
                _meta = meta;
                Console.WriteLine("[ApplyExtractedMeta] Active tab — bound _meta and calling StateHasChanged().");
                StateHasChanged();
            }
            else
            {
                Console.WriteLine($"[ApplyExtractedMeta] Not active tab (active={_activeTabId}) — cached only.");
            }

            try { await JSRuntime.InvokeVoidAsync("saveIPubEditMeta", tab.Id.ToString(), meta); Console.WriteLine("[ApplyExtractedMeta] saveIPubEditMeta OK"); }
            catch (Exception saveEx) { Console.WriteLine($"[ApplyExtractedMeta] saveIPubEditMeta failed: {saveEx.Message}"); }

            try { await JSRuntime.InvokeVoidAsync("applyMetadata", meta); Console.WriteLine("[ApplyExtractedMeta] applyMetadata OK"); }
            catch (Exception applyEx) { Console.WriteLine($"[ApplyExtractedMeta] applyMetadata failed: {applyEx.Message}"); }

            await RefreshCeTemplatesAsync();
            Console.WriteLine("[ApplyExtractedMeta] RefreshCeTemplatesAsync done.");
            // CeTemplate options are now populated for the chosen Publisher.
            if (_ceTemplateOptions.Count > 0)
                WarnIfUnmatchedDropdownValue("CeTemplate", meta.CeTemplate, _ceTemplateOptions);
            Console.WriteLine("[ApplyExtractedMeta] ===== END =====");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ApplyExtractedMeta] EXCEPTION: {ex.GetType().Name}: {ex.Message}");
            Console.WriteLine("[ApplyExtractedMeta] ===== END (exception) =====");
        }
    }

    private static void MergeDtoIntoMeta(IPubMetaDto d, IPubEditMeta m)
    {
        if (!string.IsNullOrWhiteSpace(d.XmlType))            m.XmlType = d.XmlType!;
        if (!string.IsNullOrWhiteSpace(d.Publisher))          m.Publisher = d.Publisher!;
        if (!string.IsNullOrWhiteSpace(d.JobCard))            m.JobCard = d.JobCard!;
        if (!string.IsNullOrWhiteSpace(d.CeTemplate))         m.CeTemplate = d.CeTemplate!;
        if (!string.IsNullOrWhiteSpace(d.BookOrJournalId))    m.BookOrJournalId = d.BookOrJournalId!;
        if (d.Copyedit.HasValue)                              m.Copyedit = d.Copyedit.Value;
        if (d.PreEditing.HasValue)                            m.PreEditing = d.PreEditing.Value;
        if (d.Testing.HasValue)                               m.Testing = d.Testing.Value;
        if (!string.IsNullOrWhiteSpace(d.Dtd))                m.Dtd = d.Dtd!;
        if (!string.IsNullOrWhiteSpace(d.BookTitle))          m.BookTitle = d.BookTitle!;
        if (!string.IsNullOrWhiteSpace(d.Isbn))               m.Isbn = d.Isbn!;
        if (!string.IsNullOrWhiteSpace(d.Month))              m.Month = d.Month!;
        if (!string.IsNullOrWhiteSpace(d.Year))               m.Year = d.Year!;
        if (!string.IsNullOrWhiteSpace(d.PaginationPlatform)) m.PaginationPlatform = d.PaginationPlatform!;
        if (!string.IsNullOrWhiteSpace(d.Country))            m.Country = d.Country!;
        if (!string.IsNullOrWhiteSpace(d.ArticleType))        m.ArticleType = d.ArticleType!;
        if (!string.IsNullOrWhiteSpace(d.Doi))                m.Doi = d.Doi!;
        if (!string.IsNullOrWhiteSpace(d.Language))           m.Language = d.Language!;
        if (!string.IsNullOrWhiteSpace(d.ProcessType))        m.ProcessType = d.ProcessType!;
        if (!string.IsNullOrWhiteSpace(d.JournalName))        m.JournalName = d.JournalName!;
        if (!string.IsNullOrWhiteSpace(d.JournalTitle))       m.JournalTitle = d.JournalTitle!;
        if (!string.IsNullOrWhiteSpace(d.PIssn))              m.PIssn = d.PIssn!;
        if (!string.IsNullOrWhiteSpace(d.EIssn))              m.EIssn = d.EIssn!;
        if (!string.IsNullOrWhiteSpace(d.Copyrights))         m.Copyrights = d.Copyrights!;
        if (!string.IsNullOrWhiteSpace(d.PublisherImprint))   m.PublisherImprint = d.PublisherImprint!;
        if (!string.IsNullOrWhiteSpace(d.ArticleId))          m.ArticleId = d.ArticleId!;
        if (!string.IsNullOrWhiteSpace(d.DocumentType))       m.DocumentType = d.DocumentType!;
    }

    // ═════════════════════════════════════════════════════════════════════════
    // SAVE — Notepad-style logic:
    //   1. If file handle exists → overwrite silently (no picker)
    //   2. If no handle → redirect to Save As (opens OS file picker)
    // ═════════════════════════════════════════════════════════════════════════
    private async Task SaveDocument()
    {
        if (ActiveTab == null) { SetStatus("❌ No document to save.", true); return; }

        // If tab was marked empty (new doc), check if user actually typed something
        if (ActiveTab.IsEmpty)
        {
            var check = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(check)) { SetStatus("❌ No document to save.", true); return; }
            ActiveTab.IsEmpty = false; // user has content now
        }

        var tabId = ActiveTab.Id.ToString();

        // Check if we have File System Access API and an existing handle
        var hasApi    = await JSRuntime.InvokeAsync<bool>("hasFileSystemAccess");
        var hasHandle = hasApi && await JSRuntime.InvokeAsync<bool>("hasFileHandle", tabId);

if (!hasHandle)
{
    // No previous save location → trigger Save As (file picker)
    await SaveAsDocument();
    return;
}


        // We have a handle — convert to bytes on server, then overwrite the file
        SetStatus("⏳ Saving…", false);
        try
        {
            var sfdt = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(sfdt)) { SetStatus("❌ Nothing to save.", true); return; }
            await JSRuntime.InvokeVoidAsync("storeSfdtToDb", ActiveTab.Id.ToString(), sfdt);

            using var saveStream = await DocumentService.SaveAsync(sfdt, ActiveTab.FileName);
            using var saveMs = new MemoryStream();
            saveStream.CopyTo(saveMs);
            var base64 = Convert.ToBase64String(saveMs.ToArray());
            var result  = await JSRuntime.InvokeAsync<string>("saveToExistingHandle", tabId, base64);

            if (result == "OK")
            {
                ActiveTab.IsModified = false;
                await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", tabId);
                _autoSaveLabel = string.Empty;
                SetStatus($"✅ Saved: {ActiveTab.FileName}", false);
            }
            else if (result == "DELETED")
            {
                // File was deleted from disk — show Notepad-style "Cannot find" popup
                _missingFileName = ActiveTab.FileName;
                _showFileNotFoundModal = true;
                SetStatus("", false);
            }
            else if (result == "NO_HANDLE")
            {
                // Handle was lost (permission denied, etc.) → fall back to Save As
                await SaveAsDocument();
                return;
            }
            else
            {
                SetStatus($"❌ {result}", true);
            }
            StateHasChanged();
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // SAVE AS — Always opens OS native file picker
    // ═════════════════════════════════════════════════════════════════════════
    private async Task SaveAsDocument()
    {
        if (ActiveTab == null) { SetStatus("❌ No document to save.", true); return; }

        // If tab was marked empty, check if user actually typed something
        if (ActiveTab.IsEmpty)
        {
            var check = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(check)) { SetStatus("❌ No document to save.", true); return; }
            ActiveTab.IsEmpty = false;
        }

        var hasApi = await JSRuntime.InvokeAsync<bool>("hasFileSystemAccess");
        if (!hasApi)
        {
            await FallbackDownloadSave();
            return;
        }

        var tabId     = ActiveTab.Id.ToString();
        var formatExt = Path.GetExtension(ActiveTab.FileName).ToLowerInvariant();
        if (formatExt is not (".docx" or ".doc" or ".rtf" or ".txt" or ".xml")) formatExt = ".docx";

        SetStatus("⏳ Saving…", false);
        StateHasChanged();

        try
        {
            // Single JS call: opens picker immediately (preserves user gesture),
            // then serializes, POSTs to server, writes to file
            var result = await JSRuntime.InvokeAsync<string>(
                "saveAsComplete", tabId, ActiveTab.FileName, formatExt, (string?)null);

            if (result == "CANCELLED")
            {
                SetStatus("Save cancelled.", false);
            }
            else if (result.StartsWith("ERROR:"))
            {
                SetStatus($"❌ {result[6..]}", true);
            }
            else if (result.StartsWith("OK:"))
            {
                var chosenName = result[3..];
                ActiveTab.FileName   = chosenName;
                ActiveTab.IsModified = false;
                await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", tabId);
                _autoSaveLabel = string.Empty;
                await StartAutoSaveForActiveTab();
                await PushRecentFile(chosenName);
                SetStatus($"✅ Saved: {chosenName}", false);
            }
            StateHasChanged();
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // Fallback for browsers without File System Access API
    private async Task FallbackDownloadSave()
    {
        SetStatus("⏳ Saving…", false);
        try
        {
            var sfdt = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(sfdt)) { SetStatus("❌ Nothing to save.", true); return; }
            ActiveTab!.IsModified = false;
            using var saveStream = await DocumentService.SaveAsync(sfdt, ActiveTab.FileName);
            using var saveMs = new MemoryStream();
            saveStream.CopyTo(saveMs);
            var base64 = Convert.ToBase64String(saveMs.ToArray());
            await JSRuntime.InvokeVoidAsync("downloadFile", base64, ActiveTab.FileName);
            await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", ActiveTab.Id.ToString());
            _autoSaveLabel = string.Empty;
            SetStatus($"✅ Saved: {ActiveTab.FileName}", false); StateHasChanged();
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // FILE NOT FOUND MODAL — handles deleted file scenario
    // ═════════════════════════════════════════════════════════════════════════
    private void CloseFileNotFoundModal()
