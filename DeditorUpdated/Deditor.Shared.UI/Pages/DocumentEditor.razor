    // ── AI Manuscript Processor ───────────────────────────────────────────
    private async Task ProcessManuscript()
    {
        if (_manuscriptProcessing) return;
        _manuscriptProcessing = true;
        StateHasChanged();

        try
        {
            // Step A: Get current document SFDT
            var sfdt = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(sfdt))
            {
                SetStatus("❌ No document content to analyze.", true);
                return;
            }

            // Step B+C: Process via service → Claude API → DocIO Compare → SFDT back
            var result = await ManuscriptService.ProcessAsync(sfdt);
            if (result == null || string.IsNullOrEmpty(result.Sfdt))
            {
                SetStatus("❌ No result returned from AI.", true);
                return;
            }

            // Step D: Load comparison SFDT into editor with track changes enabled
            await JSRuntime.InvokeVoidAsync("loadManuscriptResult", result.Sfdt);

            SetStatus($"✦ AI found {result.ChangesApplied} suggestions (of {result.TotalSuggestions}). Use Review tab to Accept/Reject.", false);
        }
        catch (Exception ex)
        {
            SetStatus($"❌ Error: {ex.Message}", true);
        }
        finally
        {
            _manuscriptProcessing = false;
            StateHasChanged();
        }
    }

