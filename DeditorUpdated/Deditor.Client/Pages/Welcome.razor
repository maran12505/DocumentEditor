@page "/welcome"
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<PageTitle>DEditor — Welcome</PageTitle>

<div class="welcome-root" data-theme="@(_isDark ? "dark" : "")">

    <!-- ══ Left Panel ══════════════════════════════════════════════════════ -->
    <aside class="welcome-left">
        <div class="welcome-brand">
            <img src="@(_isDark ? "images/Logo1.png" : "images/Logo.png")" alt="Logo" class="welcome-logo" />
            <div>
                <div class="welcome-brand-name">DEditor</div>
                <div class="welcome-brand-sub">Document Editor</div>
            </div>
        </div>

        <!-- Actions -->
        <div class="welcome-actions">
            <button class="welcome-action-btn welcome-action-new" @onclick="NewDocument">
                <div class="welcome-action-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                </div>
                <div>
                    <div class="welcome-action-label">New Document</div>
                    <div class="welcome-action-desc">Start with a blank page</div>
                </div>
            </button>

            <button class="welcome-action-btn" @onclick="OpenFile">
                <div class="welcome-action-icon welcome-action-icon-open">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                    </svg>
                </div>
                <div>
                    <div class="welcome-action-label">Open File</div>
                    <div class="welcome-action-desc">.docx, .doc, .rtf, .txt, .sfdt</div>
                </div>
            </button>
        </div>

        <!-- Recent Files -->
        <div class="welcome-recent">
            <div class="welcome-section-title">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" opacity=".5">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                Recent Files
            </div>

            @if (_recentFiles.Count == 0)
            {
                <div class="welcome-recent-empty">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    <span>No recent files yet</span>
                </div>
            }
            else
            {
                @foreach (var file in _recentFiles.Take(8))
                {
                    <div class="welcome-recent-item" @onclick="() => OpenRecent(file.Name)">
                        <div class="welcome-recent-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                        </div>
                        <div class="welcome-recent-info">
                            <div class="welcome-recent-name">@file.Name</div>
                            <div class="welcome-recent-time">@file.TimeLabel</div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Bottom controls -->
        <div class="welcome-left-bottom">
            <button class="welcome-theme-btn" @onclick="ToggleTheme" title="Toggle theme">
                @if (_isDark)
                {
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="5"/>
                        <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                }
                else
                {
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                }
            </button>
            <span class="welcome-version">v1.0</span>
        </div>
    </aside>

    <!-- ══ Main Content ════════════════════════════════════════════════════ -->
    <main class="welcome-main">
        <div class="welcome-main-inner">

            <!-- Hero -->
            <div class="welcome-hero">
                <h1 class="welcome-title">Welcome to DEditor</h1>
                <p class="welcome-subtitle">Create, edit, and collaborate on documents with a powerful browser-based editor.</p>
            </div>

            <!-- Quick Start -->
            <div class="welcome-section-title welcome-section-title-main">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" opacity=".5">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                Start New
            </div>

            <div class="welcome-templates">
                @foreach (var tmpl in _templates)
                {
                    <div class="welcome-template-card" @onclick="() => NewFromTemplate(tmpl.Id)">
                        <div class="welcome-template-preview" style="background:@tmpl.Color;">
                            <div class="welcome-template-icon">@tmpl.Icon</div>
                            @if (tmpl.Id == "blank")
                            {
                                <div class="welcome-template-lines">
                                    <div class="wt-line" style="width:60%"></div>
                                    <div class="wt-line" style="width:80%"></div>
                                    <div class="wt-line" style="width:45%"></div>
                                    <div class="wt-line" style="width:70%"></div>
                                </div>
                            }
                        </div>
                        <div class="welcome-template-name">@tmpl.Name</div>
                        <div class="welcome-template-desc">@tmpl.Description</div>
                    </div>
                }
            </div>

            <!-- Keyboard Shortcuts -->
            <div class="welcome-section-title welcome-section-title-main" style="margin-top:32px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" opacity=".5">
                    <rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M8 12h.01M12 12h.01M16 12h.01M7 16h10"/>
                </svg>
                Keyboard Shortcuts
            </div>

            <div class="welcome-shortcuts">
                <div class="welcome-shortcut"><kbd>Ctrl</kbd> + <kbd>S</kbd> <span>Save</span></div>
                <div class="welcome-shortcut"><kbd>Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>S</kbd> <span>Save As</span></div>
                <div class="welcome-shortcut"><kbd>Ctrl</kbd> + <kbd>B</kbd> <span>Bold</span></div>
                <div class="welcome-shortcut"><kbd>Ctrl</kbd> + <kbd>I</kbd> <span>Italic</span></div>
                <div class="welcome-shortcut"><kbd>Ctrl</kbd> + <kbd>U</kbd> <span>Underline</span></div>
                <div class="welcome-shortcut"><kbd>Ctrl</kbd> + <kbd>F</kbd> <span>Find</span></div>
                <div class="welcome-shortcut"><kbd>/</kbd> <span>Insert Snippet</span></div>
                <div class="welcome-shortcut"><kbd>Esc</kbd> <span>Exit Focus Mode</span></div>
            </div>
        </div>
    </main>
</div>

@code {
    private bool _isDark = false;
    private List<RecentFile> _recentFiles = new();

    private readonly List<Template> _templates = new()
    {
        new("blank",   "📄", "Blank Document",  "Start from scratch",           "#F0EDE8"),
        new("report",  "📊", "Report",          "Professional report layout",    "#E8EFF8"),
        new("letter",  "✉️",  "Letter",          "Formal business letter",        "#F0F8E8"),
        new("essay",   "📝", "Essay",           "Academic essay with headings",  "#F8F0E8"),
        new("memo",    "📋", "Memo",            "Internal memo template",        "#E8F0F8"),
        new("article", "📰", "Article",         "Journal article format",        "#F8E8F0"),
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load theme preference
            var theme = await JSRuntime.InvokeAsync<string>("eval", "localStorage.getItem('deditor-theme') || 'light'");
            if (theme == "dark") { _isDark = true; StateHasChanged(); }

            // Load recent files
            await LoadRecentFiles();
        }
    }

    private async Task LoadRecentFiles()
    {
        try
        {
            var arr = await JSRuntime.InvokeAsync<RecentFileDto[]>("getRecentFiles");
            _recentFiles = arr?.Select(r => new RecentFile
            {
                Name = r.Name,
                OpenedAt = r.OpenedAt,
                TimeLabel = FormatRelativeTime(r.OpenedAt)
            }).ToList() ?? new();
            StateHasChanged();
        }
        catch { _recentFiles = new(); }
    }

    private void NewDocument() => Nav.NavigateTo("/");

    private void OpenFile() => Nav.NavigateTo("/");
    // The editor will handle the file picker — we just navigate there

    private void NewFromTemplate(string templateId)
    {
        // Navigate to editor — could pass template as query param
        Nav.NavigateTo($"/?template={templateId}");
    }

    private void OpenRecent(string fileName)
    {
        Nav.NavigateTo("/");
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JSRuntime.InvokeVoidAsync("eval",
            $"localStorage.setItem('deditor-theme','{(_isDark ? "dark" : "light")}')");
        StateHasChanged();
    }

    private static string FormatRelativeTime(string? iso)
    {
        if (string.IsNullOrEmpty(iso) || !DateTime.TryParse(iso, out var dt)) return "recently";
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("MMM d");
    }

    private record Template(string Id, string Icon, string Name, string Description, string Color);
    private class RecentFile { public string Name { get; set; } = ""; public string OpenedAt { get; set; } = ""; public string TimeLabel { get; set; } = ""; }
    private class RecentFileDto { public string Name { get; set; } = ""; public string OpenedAt { get; set; } = ""; }
}

<style>
    /* ══════════════════════════════════════════════════════════════════
       WELCOME PAGE — Microsoft Word-style Start Screen
    ══════════════════════════════════════════════════════════════════ */

    .welcome-root {
        display: flex;
        height: 100vh;
        overflow: hidden;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        background: #FAFAF9;
        color: #37352F;
    }

    /* ── Dark Mode ──────────────────────────────────────────────── */
    .welcome-root[data-theme="dark"] {
        background: #1E1E1E;
        color: #E0DDD8;
    }
    .welcome-root[data-theme="dark"] .welcome-left {
        background: #181818;
        border-color: #2A2A2A;
    }
    .welcome-root[data-theme="dark"] .welcome-action-btn {
        background: #252525;
        border-color: #333;
        color: #E0DDD8;
    }
    .welcome-root[data-theme="dark"] .welcome-action-btn:hover {
        background: #2D2D2D;
        border-color: #444;
    }
    .welcome-root[data-theme="dark"] .welcome-action-new {
        background: #1a3a5c;
        border-color: #2383E2;
    }
    .welcome-root[data-theme="dark"] .welcome-recent-item:hover { background: #252525; }
    .welcome-root[data-theme="dark"] .welcome-template-card:hover { background: #252525; }
    .welcome-root[data-theme="dark"] .welcome-main { background: #1E1E1E; }
    .welcome-root[data-theme="dark"] .welcome-template-preview { opacity: .85; }
    .welcome-root[data-theme="dark"] .welcome-shortcut kbd {
        background: #333; border-color: #444; color: #ccc;
    }
    .welcome-root[data-theme="dark"] .welcome-subtitle { color: #999; }
    .welcome-root[data-theme="dark"] .welcome-section-title { color: #888; }
    .welcome-root[data-theme="dark"] .welcome-template-desc { color: #888; }
    .welcome-root[data-theme="dark"] .welcome-recent-time { color: #666; }
    .welcome-root[data-theme="dark"] .welcome-recent-empty { color: #555; }
    .welcome-root[data-theme="dark"] .welcome-version { color: #555; }

    /* ── Left Panel ─────────────────────────────────────────────── */
    .welcome-left {
        width: 300px;
        min-width: 300px;
        background: #FFFFFF;
        border-right: 1px solid #E8E5E0;
        display: flex;
        flex-direction: column;
        padding: 0;
        overflow-y: auto;
    }

    .welcome-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 28px 24px 20px;
    }
    .welcome-logo { width: 38px; height: 38px; border-radius: 8px; object-fit: contain; }
    .welcome-brand-name { font-size: 18px; font-weight: 700; letter-spacing: -.02em; }
    .welcome-brand-sub { font-size: 11px; color: #999; font-weight: 500; margin-top: 1px; }

    /* Actions */
    .welcome-actions { padding: 8px 18px 16px; display: flex; flex-direction: column; gap: 8px; }

    .welcome-action-btn {
        display: flex;
        align-items: center;
        gap: 14px;
        width: 100%;
        padding: 14px 16px;
        border: 1px solid #E8E5E0;
        border-radius: 10px;
        background: #FAFAF9;
        cursor: pointer;
        text-align: left;
        font-family: inherit;
        transition: all .15s ease;
    }
    .welcome-action-btn:hover {
        background: #F0EDE8;
        border-color: #D6D2CB;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(0,0,0,.06);
    }

    .welcome-action-new {
        background: #EBF3FD;
        border-color: #B8D4F0;
    }
    .welcome-action-new:hover {
        background: #D9E8FA;
        border-color: #2383E2;
    }

    .welcome-action-icon {
        width: 40px; height: 40px; border-radius: 10px;
        background: #2383E2; color: #fff;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .welcome-action-icon-open { background: #7C6F64; }

    .welcome-action-label { font-size: 13px; font-weight: 650; color: inherit; }
    .welcome-action-desc { font-size: 11px; color: #999; margin-top: 2px; }

    /* Section titles */
    .welcome-section-title {
        display: flex; align-items: center; gap: 6px;
        font-size: 10px; font-weight: 700; text-transform: uppercase;
        letter-spacing: .8px; color: #999; margin-bottom: 10px;
        user-select: none;
    }
    .welcome-section-title-main { font-size: 11px; margin-bottom: 14px; }

    /* Recent Files */
    .welcome-recent { padding: 12px 18px; flex: 1; }
    .welcome-recent-empty {
        display: flex; flex-direction: column; align-items: center; gap: 8px;
        padding: 24px 0; color: #BBB; font-size: 12px;
    }
    .welcome-recent-item {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 10px; border-radius: 7px;
        cursor: pointer; transition: background .12s;
    }
    .welcome-recent-item:hover { background: #F5F3F0; }
    .welcome-recent-icon {
        width: 30px; height: 30px; border-radius: 6px;
        background: #F0EDE8; display: flex; align-items: center; justify-content: center;
        color: #7C6F64; flex-shrink: 0;
    }
    .welcome-recent-info { flex: 1; min-width: 0; }
    .welcome-recent-name {
        font-size: 12.5px; font-weight: 600; color: inherit;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .welcome-recent-time { font-size: 10.5px; color: #BBB; margin-top: 1px; }

    /* Bottom */
    .welcome-left-bottom {
        padding: 14px 18px; border-top: 1px solid #F0EDE8;
        display: flex; align-items: center; justify-content: space-between;
    }
    .welcome-theme-btn {
        background: none; border: none; cursor: pointer;
        color: #999; padding: 6px; border-radius: 6px;
        transition: background .12s, color .12s;
    }
    .welcome-theme-btn:hover { background: #F0EDE8; color: #555; }
    .welcome-version { font-size: 10px; color: #CCC; }

    /* ── Main Content ───────────────────────────────────────────── */
    .welcome-main {
        flex: 1;
        overflow-y: auto;
        background: #FAFAF9;
    }
    .welcome-main-inner {
        max-width: 820px;
        margin: 0 auto;
        padding: 48px 40px 60px;
    }

    /* Hero */
    .welcome-hero { margin-bottom: 36px; }
    .welcome-title {
        font-size: 28px; font-weight: 750; letter-spacing: -.03em;
        margin: 0 0 8px; color: inherit;
    }
    .welcome-subtitle {
        font-size: 14px; color: #888; line-height: 1.5; margin: 0;
        max-width: 500px;
    }

    /* Template Gallery */
    .welcome-templates {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 14px;
    }

    .welcome-template-card {
        cursor: pointer;
        border-radius: 10px;
        padding: 0;
        transition: all .15s ease;
        background: transparent;
    }
    .welcome-template-card:hover {
        transform: translateY(-3px);
        background: #F5F3F0;
    }
    .welcome-template-card:hover .welcome-template-preview {
        box-shadow: 0 8px 24px rgba(0,0,0,.1);
    }

    .welcome-template-preview {
        height: 120px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,.06);
        transition: box-shadow .15s ease;
    }
    .welcome-template-icon { font-size: 28px; }
    .welcome-template-lines {
        position: absolute; bottom: 14px; left: 16px; right: 16px;
        display: flex; flex-direction: column; gap: 5px;
    }
    .wt-line {
        height: 3px; background: rgba(0,0,0,.08); border-radius: 2px;
    }

    .welcome-template-name {
        font-size: 12.5px; font-weight: 650; margin-top: 10px;
        padding: 0 4px; color: inherit;
    }
    .welcome-template-desc {
        font-size: 10.5px; color: #999; padding: 0 4px; margin-top: 2px;
        margin-bottom: 8px;
    }

    /* Keyboard Shortcuts */
    .welcome-shortcuts {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px 24px;
    }
    .welcome-shortcut {
        display: flex; align-items: center; gap: 6px;
        font-size: 12px; color: #888; padding: 6px 0;
    }
    .welcome-shortcut span { margin-left: auto; font-weight: 500; color: inherit; }
    .welcome-shortcut kbd {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 22px; height: 22px; padding: 0 6px;
        background: #F0EDE8; border: 1px solid #E0DDD8;
        border-radius: 4px; font-size: 10px; font-weight: 600;
        font-family: inherit; color: #555;
    }

    /* ── Animation ──────────────────────────────────────────────── */
    .welcome-root { animation: welcomeFadeIn .4s ease; }
    @@keyframes welcomeFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    .welcome-template-card {
        animation: welcomeSlideUp .4s ease backwards;
    }
    .welcome-template-card:nth-child(1) { animation-delay: .05s; }
    .welcome-template-card:nth-child(2) { animation-delay: .1s; }
    .welcome-template-card:nth-child(3) { animation-delay: .15s; }
    .welcome-template-card:nth-child(4) { animation-delay: .2s; }
    .welcome-template-card:nth-child(5) { animation-delay: .25s; }
    .welcome-template-card:nth-child(6) { animation-delay: .3s; }
    @@keyframes welcomeSlideUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ── Responsive ─────────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .welcome-root { flex-direction: column; }
        .welcome-left { width: 100%; min-width: 100%; max-height: 50vh; border-right: none; border-bottom: 1px solid #E8E5E0; }
        .welcome-main-inner { padding: 24px 20px 40px; }
        .welcome-templates { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); }
    }
</style>
