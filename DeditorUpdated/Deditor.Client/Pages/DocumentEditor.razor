        public string TabLabel   => string.IsNullOrEmpty(FileName) ? "Untitled" : System.IO.Path.GetFileNameWithoutExtension(FileName);
        public string DisplayName => FileName.Length > 18 ? FileName[..15] + "…" : FileName;
