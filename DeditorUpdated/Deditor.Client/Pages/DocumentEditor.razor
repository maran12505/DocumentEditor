    private async Task HandleFileNotFoundSaveAs()
    {
        _showFileNotFoundModal = false;
        StateHasChanged();

        // Clear the stale handle — force Save As to open a fresh picker
        if (ActiveTab != null)
        {
            await JSRuntime.InvokeVoidAsync("clearFileHandle", ActiveTab.Id.ToString());
        }

        // Open Save As picker so user can pick a new location
        await SaveAsDocument();
    }

