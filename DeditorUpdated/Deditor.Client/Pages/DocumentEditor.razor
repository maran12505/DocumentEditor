    private async Task ScrollChatToBottom()
    {
        await Task.Delay(80);
        try { await JSRuntime.InvokeVoidAsync("eval","var el=document.getElementById('chatMessages');if(el)el.scrollTop=el.scrollHeight;"); } catch { }
    }
    private static string Truncate(string s, int max) => s.Length <= max ? s : s[..max] + "…";
    private static string TrimToWordLimit(string text, int maxWords)
    {
        var w = text.Split(' ');
        return w.Length <= maxWords ? text : string.Join(' ', w[..maxWords]);
    }
    private static string FormatAsHtml(string text)
    {
        var html = System.Web.HttpUtility.HtmlEncode(text);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*(.+?)\*",     "<em>$1</em>");
        return html.Replace("\n","<br/>");
    }
    private static string? ExtractImprovedText(string r)
    {
        foreach (var p in new[]{"improved version:","revised version:","copyedited version:","here is the"})
        {
            var idx = r.ToLower().IndexOf(p);
            if (idx < 0) continue;
            var after = r[(idx + p.Length)..].Trim().TrimStart('\n','\r',':').Trim();
            var end   = after.IndexOf('\n');
            return end > 0 ? after[..end].Trim() : after.Trim();
        }
        return null;
    }
    private void SetStatus(string msg, bool isError)
    {
        _statusMessage = msg; _statusClass = isError ? "n-status-error" : "n-status-ok"; StateHasChanged();
    }
    private async Task PreviewSuggestion(ChatMessage msg)
    {
        var original = await JSRuntime.InvokeAsync<string>("getSelectedText");
        if (string.IsNullOrWhiteSpace(original)) { SetStatus("⚠️ Select text to preview changes.", true); return; }
        var html = $"<div style='margin-bottom:8px;'><strong>Original:</strong><br/><span style='color:#D44C47'>{System.Web.HttpUtility.HtmlEncode(original)}</span></div>"
                 + $"<div style='margin-bottom:8px;'><strong>AI Suggestion:</strong><br/><span style='color:#0F7B6C'>{System.Web.HttpUtility.HtmlEncode(msg.ApplicableText!)}</span></div>"
                 + "<div style='font-size:.73rem;color:#787774;'>Click <strong>Apply</strong> below to insert as tracked change.</div>";
        AddMessage("assistant", html, msg.ApplicableText);
        await ScrollChatToBottom();
    }

