                @if (_chatLoading)
                {
                    <div class="n-ai-msg n-ai-msg-assistant">
                        <div class="n-ai-msg-label">AI</div>
                        <div class="n-ai-msg-body n-ai-typing"><span></span><span></span><span></span></div>
                    </div>
                }
            </div>
            <div class="n-ai-input-row">
                <textarea class="n-ai-input" placeholder="Ask about your document…"
                          @bind="_chatInput" @bind:event="oninput"
                          @onkeydown="HandleChatKeyDown" rows="2"
                          disabled="@_chatLoading"></textarea>
                <button class="n-ai-send" @onclick="SendChatMessage"
                        disabled="@(_chatLoading || string.IsNullOrWhiteSpace(_chatInput))">➤</button>
            </div>
        </aside>
    }

</div>

<!-- ══ Sheet Tab Bar ══════════════════════════════════════════════════════ -->
<div class="n-sheet-bar">
    <button class="n-sheet-add" @onclick="NewTab" title="Add sheet">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
    </button>
    <div class="n-sheet-tabs">
        @foreach (var tab in _tabs)
        {
            <div class="n-sheet-tab @(tab.Id == _activeTabId ? "active" : "")"
                 @onclick="() => SwitchTab(tab.Id)" title="@tab.FileName">
                @if (_renamingTabId == tab.Id)
                {
                    <input class="n-sheet-rename-input"
                           @bind="_renameValue" @bind:event="oninput"
                           @onblur="CommitRename" @onkeydown="HandleRenameKey"
                           maxlength="40" @ref="_renameInputRef" />
                }
                else
                {
                    <span class="n-sheet-tab-name" @ondblclick="() => StartRename(tab)">@tab.TabLabel</span>
                    @if (tab.IsModified) { <span class="n-sheet-tab-dirty" title="Unsaved changes"></span> }
                }
                @if (_tabs.Count > 1)
                {
                    <button class="n-sheet-tab-close" @onclick:stopPropagation="true"
                            @onclick="() => CloseTab(tab.Id)" title="Close sheet">✕</button>
                }
            </div>
        }
    </div>
</div>

@if (_slashPickerVisible)
{
    <div class="n-slash-picker" id="slashPicker"
         style="left:@(_slashPickerX.ToString("F0"))px;top:@(_slashPickerY.ToString("F0"))px;">
        <div class="n-slash-header">Snippets — press Esc to close</div>
        @for (int i = 0; i < _snippets.Count; i++)
        {
            var localIdx = i;
            var s = _snippets[i];
            <div class="n-slash-item @(_slashActiveIdx == localIdx ? "n-slash-active" : "")"
                 @onclick="() => InsertSnippet(localIdx)"
                 @onmouseover="() => _slashActiveIdx = localIdx">
                <span class="n-slash-icon">@s.Icon</span>
                <div>
                    <div class="n-slash-label">@s.Label</div>
                    <div class="n-slash-desc">@s.Desc</div>
                </div>
            </div>
        }
    </div>
}

<!-- ══ File Not Found Modal ══════════════════════════════════════════════ -->
@if (_showFileNotFoundModal)
{
    <div class="n-modal-overlay" @onclick="CloseFileNotFoundModal">
        <div class="n-modal" @onclick:stopPropagation="true">
            <div class="n-modal-header">
                <h3>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#D44C47" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                    DEditor
                </h3>
                <button class="n-modal-close" @onclick="CloseFileNotFoundModal">✕</button>
            </div>
            <div class="n-modal-body">
                Cannot find the <code>@_missingFileName</code> file.
                <br/><br/>
                It may have been moved, renamed, or deleted. Would you like to save it to a new location?
            </div>
            <div class="n-modal-footer">
                <button class="n-modal-btn n-modal-btn-secondary" @onclick="CloseFileNotFoundModal">Cancel</button>
                <button class="n-modal-btn n-modal-btn-primary" @onclick="HandleFileNotFoundSaveAs">Save As</button>
            </div>
        </div>
    </div>
}
<!-- ══ Unsaved Changes Modal ═════════════════════════════════════════════ -->
@if (_showUnsavedModal)
{
    <div class="n-modal-overlay" @onclick="CancelCloseTab">
        <div class="n-modal" @onclick:stopPropagation="true">
            <div class="n-modal-header">
                <h3>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E9A23B" stroke-width="2">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    Unsaved Changes
                </h3>
                <button class="n-modal-close" @onclick="CancelCloseTab">✕</button>
            </div>
            <div class="n-modal-body">
                <strong>@_pendingCloseFileName</strong> has unsaved changes.
                <br/><br/>
                Do you want to save before closing?
            </div>
            <div class="n-modal-footer">
                <button class="n-modal-btn n-modal-btn-secondary" @onclick="CancelCloseTab">Cancel</button>
                <button class="n-modal-btn" style="background:#D44C47;color:#fff;border-color:#D44C47;" @onclick="DiscardAndCloseTab">Discard</button>
                <button class="n-modal-btn n-modal-btn-primary" @onclick="SaveAndCloseTab">Save</button>
            </div>
        </div>
    </div>
}
</div>

@code {
    private string _statusMessage = string.Empty;
