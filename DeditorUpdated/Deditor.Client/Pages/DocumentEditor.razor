private async Task NewTab()
    {
        // Create a new tab with its own editor instance (no serialize/deserialize!)
        var tab = new DocTab { FileName = "Untitled.docx", IsEmpty = true };
        _tabs.Add(tab); _activeTabId = tab.Id;
        await JSRuntime.InvokeVoidAsync("createEditorForTab", tab.Id.ToString());
        StateHasChanged();
    }

    private async Task StartRename(DocTab tab) { _renamingTabId = tab.Id; _renameValue = tab.TabLabel; StateHasChanged(); await Task.Delay(50); try { await _renameInputRef.FocusAsync(); } catch { } }
    private void CommitRename() { var tab = _tabs.FirstOrDefault(t => t.Id == _renamingTabId); if (tab != null && !string.IsNullOrWhiteSpace(_renameValue)) { var ext = System.IO.Path.GetExtension(tab.FileName); tab.FileName = _renameValue.Trim() + (string.IsNullOrEmpty(ext) ? ".docx" : ext); } _renamingTabId = Guid.Empty; StateHasChanged(); }
    private void HandleRenameKey(KeyboardEventArgs e) { if (e.Key == "Enter") CommitRename(); if (e.Key == "Escape") { _renamingTabId = Guid.Empty; StateHasChanged(); } }

private async Task SwitchTab(Guid tabId)
    {
        if (tabId == _activeTabId) return;
        var nextTab = _tabs.FirstOrDefault(t => t.Id == tabId);
        if (nextTab == null) return;
        // Just toggle visibility — NO serialize, NO IndexedDB, NO open()!
        await JSRuntime.InvokeVoidAsync("switchTab",
            _activeTabId.ToString(),
            nextTab.Id.ToString(),
            nextTab.IsEmpty);
        _activeTabId = tabId;
        StateHasChanged();
    }

private async Task CloseTab(Guid tabId)
    {
        var tab = _tabs.FirstOrDefault(t => t.Id == tabId);
        if (tab == null) return;

        // If tab has unsaved changes, show confirmation modal
        if (tab.IsModified && !tab.IsEmpty)
        {
            _pendingCloseTabId = tabId;
            _pendingCloseFileName = tab.FileName;
            _showUnsavedModal = true;
            StateHasChanged();
            return;
        }

        // No unsaved changes — close directly
        await ForceCloseTab(tabId);
    }

    private async Task ForceCloseTab(Guid tabId)
    {
        var tab = _tabs.FirstOrDefault(t => t.Id == tabId);
        if (tab == null) return;

        await JSRuntime.InvokeVoidAsync("clearFileHandle", tab.Id.ToString());

        if (_tabs.Count == 1)
        {
            // Last tab — reset it instead of closing
            tab.FileName = "Untitled.docx"; tab.IsModified = false; tab.IsEmpty = true;
            await JSRuntime.InvokeVoidAsync("loadBlankDocument");
            StateHasChanged(); return;
        }

        var idx = _tabs.IndexOf(tab); _tabs.Remove(tab);
        var next = _tabs[Math.Min(idx, _tabs.Count - 1)];
        _activeTabId = next.Id;
        // Destroy the closed tab's editor, then show the next one (already in memory!)
        await JSRuntime.InvokeVoidAsync("destroyEditorForTab", tab.Id.ToString());
        await JSRuntime.InvokeVoidAsync("switchTab", "", next.Id.ToString(), next.IsEmpty);
        StateHasChanged();
    }

    private void CancelCloseTab()
    {
        _showUnsavedModal = false;
        _pendingCloseTabId = Guid.Empty;
        StateHasChanged();
    }

    private async Task DiscardAndCloseTab()
    {
        _showUnsavedModal = false;
        var tabId = _pendingCloseTabId;
        _pendingCloseTabId = Guid.Empty;
        await ForceCloseTab(tabId);
    }

    private async Task SaveAndCloseTab()
    {
        _showUnsavedModal = false;
        var tabId = _pendingCloseTabId;
        _pendingCloseTabId = Guid.Empty;

        // Switch to the tab being closed so we can save it
        var tab = _tabs.FirstOrDefault(t => t.Id == tabId);
        if (tab != null && tabId != _activeTabId)
        {
            await SwitchTab(tabId);
        }

        // Save the document
        await SaveDocument();

        // After save completes, close the tab
        await ForceCloseTab(tabId);
    }

