        new("✍",  "Signature",   "Sign-off block",             "\n\nSincerely,\n\n[Your Name]\n[Title]\n[Email]"),
        new("📋", "Table note",  "Simple 2-column table note", "[Table X. Caption]\n\nColumn A | Column B\n---------|----------\n         |          \n"),
