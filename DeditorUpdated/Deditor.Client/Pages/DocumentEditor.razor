    private async Task NewTab()
    {
        var current = ActiveTab;
        if (current != null)
        {
            var s = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (!string.IsNullOrEmpty(s)) { current.Sfdt = s; current.IsEmpty = false; current.IsModified = true; }
            await JSRuntime.InvokeVoidAsync("autoSaveNow", current.Id.ToString(), current.FileName);
        }
        var tab = new DocTab { FileName = "Untitled.docx", IsEmpty = true };
        _tabs.Add(tab); _activeTabId = tab.Id;
        await JSRuntime.InvokeVoidAsync("loadBlankDocument");
        await StartAutoSaveForActiveTab();
        StateHasChanged();
    }

    private async Task StartRename(DocTab tab)
    {
        _renamingTabId = tab.Id; _renameValue = tab.TabLabel;
        StateHasChanged(); await Task.Delay(50);
        try { await _renameInputRef.FocusAsync(); } catch { }
    }

    private void CommitRename()
    {
        var tab = _tabs.FirstOrDefault(t => t.Id == _renamingTabId);
        if (tab != null && !string.IsNullOrWhiteSpace(_renameValue))
        {
            var ext = System.IO.Path.GetExtension(tab.FileName);
            tab.FileName = _renameValue.Trim() + (string.IsNullOrEmpty(ext) ? ".docx" : ext);
        }
        _renamingTabId = Guid.Empty; StateHasChanged();
    }

    private void HandleRenameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")  CommitRename();
        if (e.Key == "Escape") { _renamingTabId = Guid.Empty; StateHasChanged(); }
    }

    private async Task SwitchTab(Guid tabId)
    {
        if (tabId == _activeTabId) return;
        var currentTab = ActiveTab;
        var nextTab    = _tabs.FirstOrDefault(t => t.Id == tabId);
        if (nextTab == null) return;
        if (currentTab != null)
            await JSRuntime.InvokeVoidAsync("autoSaveNow", currentTab.Id.ToString(), currentTab.FileName);
        bool nextIsBlank = string.IsNullOrEmpty(nextTab.Sfdt);
        var oldSfdt = await JSRuntime.InvokeAsync<string>("saveAndSwitch",
            nextIsBlank ? null : nextTab.Sfdt, nextIsBlank);
        if (currentTab != null && !string.IsNullOrEmpty(oldSfdt)) { currentTab.Sfdt = oldSfdt; currentTab.IsEmpty = false; }
        _activeTabId = tabId;
        await StartAutoSaveForActiveTab();
        StateHasChanged();
    }

    private async Task CloseTab(Guid tabId)
    {
        var tab = _tabs.FirstOrDefault(t => t.Id == tabId);
        if (tab == null) return;
        await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", tab.Id.ToString());
        if (_tabs.Count == 1)
        {
            tab.FileName = "Untitled.docx"; tab.Sfdt = string.Empty;
            tab.IsModified = false; tab.IsEmpty = true;
            await JSRuntime.InvokeVoidAsync("loadBlankDocument");
            await StartAutoSaveForActiveTab(); StateHasChanged(); return;
        }
        var idx = _tabs.IndexOf(tab); _tabs.Remove(tab);
        var next = _tabs[Math.Min(idx, _tabs.Count - 1)]; _activeTabId = next.Id;
        await JSRuntime.InvokeVoidAsync(next.IsEmpty ? "loadBlankDocument" : "loadDocument",
            next.IsEmpty ? null! : (object)next.Sfdt);
        await StartAutoSaveForActiveTab(); StateHasChanged();
    }

    private async Task SaveCurrentTabSfdt()
    {
        var current = ActiveTab;
        if (current == null || current.IsEmpty) return;
        var sfdt = await JSRuntime.InvokeAsync<string>("getDocumentContent");
        if (!string.IsNullOrEmpty(sfdt)) { current.Sfdt = sfdt; current.IsModified = true; }
    }

