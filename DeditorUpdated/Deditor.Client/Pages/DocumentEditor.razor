    private async Task PreviewSuggestion(ChatMessage msg)
    {
        var original = await JSRuntime.InvokeAsync<string>("getSelectedText");

        if (string.IsNullOrWhiteSpace(original))
        {
            SetStatus("⚠️ Select text to preview changes.", true);
            return;
        }

        var previewHtml = $@"
            <div style='margin-bottom:8px;'>
                <strong>Original:</strong><br/>
                <span style='color:#D44C47'>{System.Web.HttpUtility.HtmlEncode(original)}</span>
            </div>
            <div style='margin-bottom:8px;'>
                <strong>AI Suggestion:</strong><br/>
                <span style='color:#0F7B6C'>{System.Web.HttpUtility.HtmlEncode(msg.ApplicableText!)}</span>
            </div>
            <div style='font-size:0.73rem;color:#787774;'>
                Click <strong>Apply</strong> below to insert as tracked change.
            </div>
        ";

        AddMessage("assistant", previewHtml, msg.ApplicableText);
        await ScrollChatToBottom();
    }
