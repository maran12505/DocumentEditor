@page "/"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@inject IJSRuntime JSRuntime
@inject HttpClient Http

<style>
    .avatar { width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#2383E2,#062b4f);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff; }
    .logo { display:flex;align-items:center;gap:8px;font-weight:600;font-size:16px; }
    .logo-img { width:28px;height:28px;object-fit:contain;border-radius:6px; }
    .logo-text { font-size:15px;color:#2f2f2f; }

    /* ── Auto-save chip ──────────────────────────────────────────────────── */
    .n-autosave-chip {
        display:inline-flex;align-items:center;gap:5px;font-size:.71rem;font-weight:500;
        color:var(--n-text-3);padding:2px 8px;border-radius:100px;
        transition:color .3s,background .3s;white-space:nowrap;user-select:none;
    }
    .n-autosave-chip.saved { color:var(--n-green);background:var(--n-green-bg); }

    /* ── Recovery banner ─────────────────────────────────────────────────── */
    .n-recovery-banner {
        display:flex;align-items:center;gap:10px;padding:9px 16px;
        background:#FFF8E6;border-bottom:1px solid #F5D87A;
        font-size:.8rem;color:#6B4A00;flex-shrink:0;flex-wrap:wrap;
    }
    [data-theme="dark"] .n-recovery-banner { background:#2A2210;border-bottom-color:#5A4500;color:#F5C842; }
    .n-recovery-banner-text { flex:1;line-height:1.4; }
    .n-recovery-btn { padding:4px 12px;border-radius:5px;border:none;font-size:.77rem;font-weight:600;font-family:inherit;cursor:pointer;transition:background .12s;white-space:nowrap; }
    .n-recovery-btn-restore { background:#F5C842;color:#3A2800; }
    .n-recovery-btn-restore:hover { background:#F0B800; }
    [data-theme="dark"] .n-recovery-btn-restore { background:#7A6000;color:#FFE580; }
    .n-recovery-btn-dismiss { background:transparent;color:#6B4A00;border:1px solid #D4AB30; }
    .n-recovery-btn-dismiss:hover { background:rgba(0,0,0,.06); }
    [data-theme="dark"] .n-recovery-btn-dismiss { color:#F5C842;border-color:#5A4500; }

    /* ── Dirty dot on tab ────────────────────────────────────────────────── */
    .n-sheet-tab-dirty { display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--n-amber);flex-shrink:0;margin-left:1px; }

    /* ── Focus mode ──────────────────────────────────────────────────────── */
    .n-focus-mode .n-topbar,
    .n-focus-mode .n-left-sidebar,
    .n-focus-mode .n-ai-sidebar,
    .n-focus-mode .n-sheet-bar { display:none !important; }
    .n-focus-mode .n-main { flex:1; }
    .n-focus-exit {
        position:fixed;top:12px;right:14px;z-index:9999;
        background:rgba(0,0,0,.55);color:#fff;border:none;
        border-radius:6px;padding:5px 14px;font-size:.78rem;font-weight:600;
        cursor:pointer;font-family:inherit;letter-spacing:.02em;
    }
    .n-focus-exit:hover { background:rgba(0,0,0,.75); }

    /* ── Slash picker ────────────────────────────────────────────────────── */
    .n-slash-picker {
        position:fixed;z-index:9998;background:var(--n-surface);
        border:1px solid var(--n-border);border-radius:8px;
        box-shadow:0 8px 24px rgba(0,0,0,.14);min-width:220px;max-height:260px;overflow-y:auto;
        font-family:inherit;padding:4px;
    }
    .n-slash-item {
        display:flex;align-items:center;gap:8px;padding:7px 10px;
        border-radius:5px;cursor:pointer;font-size:.8rem;color:var(--n-text-2);
        transition:background .1s,color .1s;
    }
    .n-slash-item:hover, .n-slash-item.n-slash-active { background:var(--n-hover);color:var(--n-text); }
    .n-slash-icon { font-size:.85rem;flex-shrink:0;width:20px;text-align:center; }
    .n-slash-label { font-weight:600;color:var(--n-text);font-size:.78rem; }
    .n-slash-desc  { font-size:.68rem;color:var(--n-text-3); }
    .n-slash-header { font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--n-text-3);padding:6px 10px 3px; }

    /* ── Sidebar tab switcher ────────────────────────────────────────────── */
    .n-left-tabs { display:flex;gap:0;padding:0 8px;border-bottom:1px solid var(--n-border-soft);flex-shrink:0;background:var(--n-surface); }
    .n-left-tab {
        padding:7px 9px;font-size:.7rem;font-weight:600;color:var(--n-text-3);
        cursor:pointer;border-bottom:2px solid transparent;transition:color .1s,border-color .1s;
        white-space:nowrap;user-select:none;
    }
    .n-left-tab:hover { color:var(--n-text); }
    .n-left-tab.active { color:var(--n-text);border-bottom-color:var(--n-accent); }

    /* ── Stats grid ──────────────────────────────────────────────────────── */
    .n-stats-grid { display:grid;grid-template-columns:1fr 1fr;gap:6px;padding:2px 0; }
    .n-stat-card { background:var(--n-hover);border-radius:6px;padding:8px 10px;display:flex;flex-direction:column;gap:2px; }
    .n-stat-value { font-size:1.05rem;font-weight:700;color:var(--n-text);line-height:1; }
    .n-stat-label { font-size:.63rem;color:var(--n-text-3);text-transform:uppercase;letter-spacing:.4px; }

    /* ── Outline ─────────────────────────────────────────────────────────── */
    .n-outline-item { display:flex;align-items:center;gap:5px;padding:5px 6px;border-radius:4px;cursor:pointer;font-size:.76rem;color:var(--n-text-2);transition:background .1s,color .1s;line-height:1.3; }
    .n-outline-item:hover { background:var(--n-hover);color:var(--n-text); }
    .n-outline-h1 { padding-left:6px;font-weight:600;color:var(--n-text); }
    .n-outline-h2 { padding-left:18px; }
    .n-outline-h3 { padding-left:30px;font-size:.72rem; }
    .n-outline-dot { width:5px;height:5px;border-radius:50%;flex-shrink:0; }
    .n-outline-h1 .n-outline-dot { background:var(--n-accent); }
    .n-outline-h2 .n-outline-dot { background:var(--n-text-3); }
    .n-outline-h3 .n-outline-dot { background:var(--n-border); }

    /* ── Recent files ────────────────────────────────────────────────────── */
    .n-recent-item { display:flex;align-items:center;gap:7px;padding:6px 8px;border-radius:5px;cursor:pointer;transition:background .1s; }
    .n-recent-item:hover { background:var(--n-hover); }
    .n-recent-name { font-size:.77rem;font-weight:500;color:var(--n-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1; }
    .n-recent-time { font-size:.65rem;color:var(--n-text-3);flex-shrink:0; }
</style>

<div class="n-workspace @(_focusMode ? "n-focus-mode" : "")">

@if (_focusMode)
{
    <button class="n-focus-exit" @onclick="ExitFocusMode" title="Exit Focus Mode (Esc)">✕ Exit</button>
}

<!-- ══ Top bar ══════════════════════════════════════════════════════════ -->
<header class="n-topbar">
    <div class="n-topbar-left">
        <button class="n-btn n-btn-ghost n-btn-icon @(_leftPaneOpen ? "active" : "")"
                @onclick="ToggleLeftPane" title="Toggle Panel">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/>
            </svg>
        </button>
        <div class="n-divider-v"></div>
        <div class="logo">
            <img src="@(_isDarkMode ? "images/Logo1.png" : "images/Logo.png")" alt="Logo" class="logo-img" />
            <span class="logo-text">DEditor</span>
        </div>
        <div class="n-divider-v"></div>
        <InputFile id="fileUploadInput" OnChange="HandleFileUpload" accept=".docx,.doc,.rtf,.txt" style="display:none" />
    </div>

    @* <div class="n-toolbar-center">
        @if (!string.IsNullOrEmpty(_autoSaveLabel))
        {
            <span class="n-autosave-chip @(_autoSaveLabel.StartsWith("✓") ? "saved" : "")">
                @if (_autoSaveLabel.StartsWith("✓"))
                {
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                }
                else
                {
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                }
                @_autoSaveLabel
            </span>
        }
    </div> *@

    <div class="n-topbar-right">
        <button class="n-btn n-btn-ghost n-btn-icon @(_navPaneOpen ? "active" : "")"
                @onclick="ToggleNavigationPane" title="Find &amp; Replace (Ctrl+F)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </button>

        <button class="n-btn n-btn-ghost n-btn-icon" @onclick="EnterFocusMode" title="Focus Mode — hide all chrome">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
            </svg>
        </button>

        <button class="n-btn n-btn-ghost n-btn-icon n-theme-toggle"
                @onclick="ToggleTheme"
                title="@(_isDarkMode ? "Switch to Light Mode" : "Switch to Dark Mode")">
            @if (_isDarkMode)
            {
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
            }
            else
            {
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            }
        </button>

        <button class="n-btn n-btn-ghost n-btn-icon n-track-btn @(_trackChangesEnabled ? "n-track-active" : "")"
                @onclick="ToggleTrackChanges"
                title="@(_trackChangesEnabled ? "Track Changes ON — click to disable" : "Track Changes OFF — click to enable")">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Track
            @if (_trackChangesEnabled) { <span class="n-track-dot" title="Track Changes is ON"></span> }
        </button>

        <div class="n-divider-v"></div>
        <button class="n-btn n-btn-ai @(_chatOpen ? "active" : "")" @onclick="ToggleChat" title="Toggle AI Assistant">
            <span class="n-ai-star">✦</span> AI
        </button>
        <div class="avatar">U</div>
    </div>
</header>

<!-- ══ Recovery Banner ═══════════════════════════════════════════════════ -->
@if (_showRecoveryBanner && _recoveryDrafts.Count > 0)
{
    <div class="n-recovery-banner">
        <span>⚠️</span>
        <span class="n-recovery-banner-text">
            <strong>Unsaved draft found</strong> — @_recoveryDrafts[0].FileName
            <span style="font-size:.7rem;opacity:.72;margin-left:4px;">(@FormatRelativeTime(_recoveryDrafts[0].SavedAt))</span>
        </span>
        <button class="n-recovery-btn n-recovery-btn-restore" @onclick="RestoreFirstDraft">↩ Restore</button>
        <button class="n-recovery-btn n-recovery-btn-dismiss" @onclick="DismissRecovery">Dismiss</button>
    </div>
}

<!-- ══ Main ══════════════════════════════════════════════════════════════ -->
<div class="n-main">

    <!-- ── Left Sidebar ──────────────────────────────────────────────── -->
    @if (_leftPaneOpen)
    {
        <aside class="n-left-sidebar">
            <div class="n-left-header">
                <div class="n-left-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/>
                    </svg>
                    Panel
                </div>
                <button class="n-left-close" @onclick="ToggleLeftPane" title="Close">✕</button>
            </div>

            <!-- Tab bar -->
            <div class="n-left-tabs">
                <div class="n-left-tab @(_leftTab=="files"   ? "active" : "")" @onclick='()=>_leftTab="files"'>Files</div>
                <div class="n-left-tab @(_leftTab=="stats"   ? "active" : "")" @onclick='()=>{_leftTab="stats";_ =RefreshStats();}'>Stats</div>
                @* <div class="n-left-tab @(_leftTab=="outline" ? "active" : "")" @onclick='()=>{_leftTab="outline";_ =RefreshOutline();}'>Outline</div> *@
                <div class="n-left-tab @(_leftTab=="recent"  ? "active" : "")" @onclick='()=>{_leftTab="recent";_ =LoadRecentFiles();}'>Recent</div>
            </div>

            <!-- ══ FILES TAB ══════════════════════════════════════════ -->
            @if (_leftTab == "files")
            {
                <div class="n-left-section">
                    <div class="n-left-section-label">File</div>
                    <div class="n-left-file-info">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                        <span class="n-left-filename" id="left-sidebar-filename">@(_currentFileName ?? "Untitled.docx")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(_autoSaveLabel))
                    {
                        <div style="font-size:.68rem;color:var(--n-text-3);padding:3px 6px 0;display:flex;align-items:center;gap:4px;">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            @_autoSaveLabel
                        </div>
                    }
                </div>
                <div class="n-left-divider"></div>
                <div class="n-left-section">
                    <div class="n-left-section-label">Actions</div>
                    <button class="n-left-action-btn" @onclick="NewDocumentFromPanel" title="New blank document">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>
                        </svg>
                        New Document
                    </button>
                    <button class="n-left-action-btn" @onclick="OpenFileDialog" title="Open .docx / .doc / .rtf / .txt">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                        </svg>
                        Open File…
                    </button>
                    <button class="n-left-action-btn" @onclick="SaveDocument" title="Save as .docx">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                            <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
                        </svg>
                        Save
                    </button>
                    <button class="n-left-action-btn" @onclick="EnterFocusMode" title="Distraction-free writing">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
                        </svg>
                        Focus Mode
                    </button>
                </div>
            }

            <!-- ══ STATS TAB ══════════════════════════════════════════ -->
            @if (_leftTab == "stats")
            {
                <div class="n-left-section">
                    <div class="n-left-section-label">Document Statistics</div>
                    <div class="n-stats-grid">
                        <div class="n-stat-card"><div class="n-stat-value">@_statWords.ToString("N0")</div><div class="n-stat-label">Words</div></div>
                        <div class="n-stat-card"><div class="n-stat-value">@_statChars.ToString("N0")</div><div class="n-stat-label">Characters</div></div>
                        <div class="n-stat-card"><div class="n-stat-value">@_statSentences.ToString("N0")</div><div class="n-stat-label">Sentences</div></div>
                        <div class="n-stat-card"><div class="n-stat-value">@_statReadMin</div><div class="n-stat-label">Min Read</div></div>
                    </div>
                    @if (_statWords > 0)
                    {
                        <div style="margin-top:8px;font-size:.71rem;color:var(--n-text-3);">
                            Avg sentence length: <strong>@_statAvgSentLen</strong> words
                        </div>
                    }
                    <button class="n-left-action-btn" style="margin-top:8px;" @onclick="RefreshStats">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                        Refresh
                    </button>
                </div>
            }

            <!-- ══ OUTLINE TAB ════════════════════════════════════════ -->
            @if (_leftTab == "outline")
            {
                <div class="n-left-section">
                    <div class="n-left-section-label">Document Outline</div>
                    @if (_outlineItems.Count == 0)
                    {
                        <div style="font-size:.74rem;color:var(--n-text-3);font-style:italic;padding:4px 2px;">
                            No headings found. Use Heading styles in the ribbon.
                        </div>
                    }
                    else
                    {
                        <div style="display:flex;flex-direction:column;gap:1px;">
                            @foreach (var item in _outlineItems)
                            {
                                <div class="n-outline-item n-outline-h@(item.Level)"
                                     @onclick="() => ScrollToHeading(item.Text)"
                                     title="@item.Text">
                                    <span class="n-outline-dot"></span>
                                    <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@item.Text</span>
                                </div>
                            }
                        </div>
                    }
                    <button class="n-left-action-btn" style="margin-top:8px;" @onclick="RefreshOutline">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                        Refresh
                    </button>
                </div>
            }

            <!-- ══ RECENT TAB ═════════════════════════════════════════ -->
            @if (_leftTab == "recent")
            {
                <div class="n-left-section">
                    <div class="n-left-section-label">Recent Files</div>
                    @if (_recentFiles.Count == 0)
                    {
                        <div style="font-size:.74rem;color:var(--n-text-3);font-style:italic;padding:4px 2px;">No recent files yet.</div>
                    }
                    else
                    {
                        @foreach (var rf in _recentFiles)
                        {
                            <div class="n-recent-item" title="@rf.Name">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;opacity:.6;">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                </svg>
                                <span class="n-recent-name">@rf.Name</span>
                                <span class="n-recent-time">@rf.TimeLabel</span>
                            </div>
                        }
                        <button class="n-left-action-btn n-left-action-btn-danger" style="margin-top:6px;" @onclick="ClearRecentFiles">
                            Clear History
                        </button>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <div class="n-left-divider"></div>
                <div class="n-left-section">
                    <span class="n-status @_statusClass">@_statusMessage</span>
                </div>
            }
        </aside>
    }

    <!-- Document editor -->
    <div class="n-editor-area">
        <div id="container1"></div>
    </div>

    <!-- AI Chat sidebar -->
    @if (_chatOpen)
    {
        <aside class="n-ai-sidebar">
            <div class="n-ai-header">
                <div class="n-ai-title"><span class="n-ai-star">✦</span> AI Assistant</div>
                <button class="n-ai-close" @onclick="ToggleChat" title="Close">✕</button>
            </div>

            <!-- Row 1: proofread / copyedit -->
            <div class="n-ai-actions">
                <button class="n-ai-action-btn" @onclick='() => QuickAction("proofread")' disabled="@_chatLoading">Proofread</button>
                <button class="n-ai-action-btn" @onclick='() => QuickAction("copyedit")'  disabled="@_chatLoading">Copyedit</button>
            </div>
            <!-- Row 2: summarize / title / tone -->
            <div class="n-ai-actions" style="border-top:none;padding-top:0;gap:4px;">
                <button class="n-ai-action-btn" @onclick='() => QuickAction("summarize")' disabled="@_chatLoading" title="1-paragraph summary">Summarize</button>
                @* <button class="n-ai-action-btn" @onclick='() => QuickAction("title")'     disabled="@_chatLoading" title="3 title suggestions">Suggest Title</button> *@
                <button class="n-ai-action-btn" @onclick='() => QuickAction("tone")'      disabled="@_chatLoading" title="Tone analysis">Tone</button>
            </div>

            <div class="n-ai-messages" id="chatMessages">
                @if (_chatMessages.Count == 0)
                {
                    <div class="n-ai-empty">
                        <div class="n-ai-empty-icon">✦</div>
                        <p>Select text and click an action, or ask me anything. Type <strong>/</strong> in the document to insert snippets.</p>
                    </div>
                }
                @foreach (var msg in _chatMessages)
                {
                    <div class="n-ai-msg n-ai-msg-@msg.Role">
                        <div class="n-ai-msg-label">@(msg.Role == "user" ? "You" : "AI")</div>
                        <div class="n-ai-msg-body">@((MarkupString)msg.HtmlContent)</div>
                        @if (msg.Role == "assistant" && !string.IsNullOrEmpty(msg.ApplicableText))
                        {
                            if (msg.HtmlContent.Contains("Original:"))
                            {
                                <button class="n-ai-apply-btn" @onclick="() => ApplySuggestion(msg.ApplicableText!)">↩ Apply to document</button>
                            }
                            else
                            {
                                <button class="n-ai-apply-btn n-ai-preview-btn" @onclick="() => PreviewSuggestion(msg)">👁 Preview</button>
                            }
                        }
                    </div>
                }
                @if (_chatLoading)
                {
                    <div class="n-ai-msg n-ai-msg-assistant">
                        <div class="n-ai-msg-label">AI</div>
                        <div class="n-ai-msg-body n-ai-typing"><span></span><span></span><span></span></div>
                    </div>
                }
            </div>

            <div class="n-ai-input-row">
                <textarea class="n-ai-input" placeholder="Ask about your document…"
                          @bind="_chatInput" @bind:event="oninput"
                          @onkeydown="HandleChatKeyDown" rows="2"
                          disabled="@_chatLoading"></textarea>
                <button class="n-ai-send" @onclick="SendChatMessage"
                        disabled="@(_chatLoading || string.IsNullOrWhiteSpace(_chatInput))">➤</button>
            </div>
        </aside>
    }

</div><!-- /n-main -->

<!-- ══ Sheet Tab Bar ══════════════════════════════════════════════════════ -->
<div class="n-sheet-bar">
    <button class="n-sheet-add" @onclick="NewTab" title="Add sheet">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
    </button>
    <div class="n-sheet-tabs">
        @foreach (var tab in _tabs)
        {
            <div class="n-sheet-tab @(tab.Id == _activeTabId ? "active" : "")"
                 @onclick="() => SwitchTab(tab.Id)" title="@tab.FileName">
                @if (_renamingTabId == tab.Id)
                {
                    <input class="n-sheet-rename-input"
                           @bind="_renameValue" @bind:event="oninput"
                           @onblur="CommitRename" @onkeydown="HandleRenameKey"
                           maxlength="40" @ref="_renameInputRef" />
                }
                else
                {
                    <span class="n-sheet-tab-name" @ondblclick="() => StartRename(tab)">@tab.TabLabel</span>
                    @if (tab.IsModified) { <span class="n-sheet-tab-dirty" title="Unsaved changes"></span> }
                }
                @if (_tabs.Count > 1)
                {
                    <button class="n-sheet-tab-close" @onclick:stopPropagation="true"
                            @onclick="() => CloseTab(tab.Id)" title="Close sheet">✕</button>
                }
            </div>
        }
    </div>
</div><!-- /n-sheet-bar -->

<!-- ══ Slash-command Snippet Picker ═══════════════════════════════════════ -->
@if (_slashPickerVisible)
{
    <div class="n-slash-picker" id="slashPicker"
         style="left:@(_slashPickerX.ToString("F0"))px;top:@(_slashPickerY.ToString("F0"))px;">
        <div class="n-slash-header">Snippets — press Esc to close</div>
        @for (int i = 0; i < _snippets.Count; i++)
        {
            var localIdx = i;
            var s = _snippets[i];
            <div class="n-slash-item @(_slashActiveIdx == localIdx ? "n-slash-active" : "")"
                 @onclick="() => InsertSnippet(localIdx)"
                 @onmouseover="() => _slashActiveIdx = localIdx">
                <span class="n-slash-icon">@s.Icon</span>
                <div>
                    <div class="n-slash-label">@s.Label</div>
                    <div class="n-slash-desc">@s.Desc</div>
                </div>
            </div>
        }
    </div>
}

</div><!-- /n-workspace -->

@code {
    // ════════════════════════════════════════════════════════════════════════
    // STATE
    // ════════════════════════════════════════════════════════════════════════
    private string _statusMessage = string.Empty;
    private string _statusClass   = string.Empty;

    // Tabs
    private List<DocTab> _tabs        = new();
    private Guid         _activeTabId = Guid.Empty;
    private DocTab?      ActiveTab    => _tabs.FirstOrDefault(t => t.Id == _activeTabId);
    private string?      _currentFileName => ActiveTab?.FileName;

    // Panes
    private bool   _navPaneOpen  = false;
    private bool   _leftPaneOpen = false;
    private bool   _chatOpen     = false;
    private string _leftTab      = "files";

    // Chat
    private bool   _chatLoading = false;
    private string _chatInput   = string.Empty;
    private List<ChatMessage> _chatMessages = new();

    // Theme / track-changes
    private bool _isDarkMode          = false;
    private bool _trackChangesEnabled = true;

    // Rename
    private Guid             _renamingTabId  = Guid.Empty;
    private string           _renameValue    = string.Empty;
    private ElementReference _renameInputRef;

    // ── Auto-save ─────────────────────────────────────────────────────────
    private string              _autoSaveLabel      = string.Empty;
    private bool                _showRecoveryBanner = false;
    private List<RecoveryDraft> _recoveryDrafts     = new();
    private DotNetObjectReference<DocumentEditor>? _selfRef;

    // ── Focus mode ────────────────────────────────────────────────────────
    private bool _focusMode = false;

    // ── Stats ─────────────────────────────────────────────────────────────
    private int    _statWords      = 0;
    private int    _statChars      = 0;
    private int    _statSentences  = 0;
    private string _statReadMin    = "0";
    private string _statAvgSentLen = "0";

    // ── Outline ───────────────────────────────────────────────────────────
    private List<OutlineItem> _outlineItems = new();

    // ── Recent files ──────────────────────────────────────────────────────
    private List<RecentFile> _recentFiles = new();

    // ── Slash picker ──────────────────────────────────────────────────────
    private bool   _slashPickerVisible = false;
    private double _slashPickerX       = 0;
    private double _slashPickerY       = 0;
    private int    _slashActiveIdx     = 0;

    private readonly List<Snippet> _snippets = new()
    {
        new("📄", "Abstract",    "Academic abstract block",   "Abstract\n\n[Your abstract text here]\n\nKeywords: "),
        new("📚", "References",  "References / Bibliography",  "References\n\n"),
        new("✍",  "Signature",   "Sign-off block",             "\n\nSincerely,\n\n[Your Name]\n[Title]\n[Email]"),
        new("📋", "Table note",  "Simple 2-column table note", "[Table X. Caption]\n\nColumn A | Column B\n---------|----------\n         |          \n"),
        new("💡", "Note",        "Callout note",               "Note: "),
        new("⚠",  "Warning",     "Warning callout",            "Warning: "),
        new("📅", "Date",        "Today's date",               DateTime.Today.ToString("MMMM d, yyyy")),
        new("📝", "TODO",        "Task placeholder",           "TODO: "),
    };

    // ════════════════════════════════════════════════════════════════════════
    // LIFECYCLE
    // ════════════════════════════════════════════════════════════════════════
    protected override Task OnInitializedAsync()
    {
        var tab = new DocTab { FileName = "Untitled.docx", IsEmpty = true };
        _tabs.Add(tab);
        _activeTabId = tab.Id;
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initializeDocumentEditor");

            var savedTheme = await JSRuntime.InvokeAsync<string>("getThemePreference");
            if (savedTheme == "dark")
            {
                _isDarkMode = true;
                await JSRuntime.InvokeVoidAsync("applyTheme", true);
                StateHasChanged();
            }

            _selfRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerAutoSaveListener", _selfRef);
            await JSRuntime.InvokeVoidAsync("registerEditorKeyListeners", _selfRef);
            await CheckForRecoveryDrafts();
            await StartAutoSaveForActiveTab();
            await LoadRecentFiles();
        }

        await JSRuntime.InvokeVoidAsync("setDocumentName", _currentFileName ?? "Untitled.docx");
    }

    // ── JS-invokable ──────────────────────────────────────────────────────
    [JSInvokable]
    public void OnAutoSaved(string timeString)
    {
        _autoSaveLabel = $"✓ Saved {timeString}";
        if (ActiveTab != null) ActiveTab.IsModified = true;
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnEscapePressed()
    {
        if (_focusMode)          { _focusMode = false; await JSRuntime.InvokeVoidAsync("resizeEditor"); }
        if (_slashPickerVisible) { _slashPickerVisible = false; }
        StateHasChanged();
    }

    [JSInvokable]
    public Task OnSlashTyped(double x, double y)
    {
        _slashPickerX      = x;
        _slashPickerY      = Math.Max(8, y - 275);
        _slashActiveIdx    = 0;
        _slashPickerVisible = true;
        StateHasChanged();
        return Task.CompletedTask;
    }
    [JSInvokable]
    public async Task NewTabFromJS() => await NewTab();
 
    [JSInvokable]
    public async Task OpenFileFromJS() => await OpenFileDialog();

    // ════════════════════════════════════════════════════════════════════════
    // FOCUS MODE
    // ════════════════════════════════════════════════════════════════════════
    private async Task EnterFocusMode()
    {
        _focusMode = true; _leftPaneOpen = false; _chatOpen = false;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("resizeEditor");
    }

    private async Task ExitFocusMode()
    {
        _focusMode = false;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("resizeEditor");
    }

    // ════════════════════════════════════════════════════════════════════════
    // DOC STATS
    // ════════════════════════════════════════════════════════════════════════
    private async Task RefreshStats()
    {
        var text = await JSRuntime.InvokeAsync<string>("getDocumentText");
        if (string.IsNullOrWhiteSpace(text))
        {
            _statWords = _statChars = _statSentences = 0;
            _statReadMin = "0"; _statAvgSentLen = "0";
            StateHasChanged(); return;
        }
        var words     = text.Split(new[]{' ','\n','\r','\t'}, StringSplitOptions.RemoveEmptyEntries);
        var sentences = text.Split(new[]{'.','!','?'},         StringSplitOptions.RemoveEmptyEntries);
        _statWords     = words.Length;
        _statChars     = text.Length;
        _statSentences = sentences.Length;
        _statReadMin   = Math.Max(1, _statWords / 200).ToString();
        _statAvgSentLen = _statSentences > 0
            ? Math.Round((double)_statWords / _statSentences, 1).ToString("0.0") : "0";
        StateHasChanged();
    }

    // ════════════════════════════════════════════════════════════════════════
    // DOCUMENT OUTLINE
    // ════════════════════════════════════════════════════════════════════════
    private async Task RefreshOutline()
    {
        try
        {
            var items = await JSRuntime.InvokeAsync<OutlineItem[]>("getDocumentOutline");
            _outlineItems = items?.ToList() ?? new();
        }
        catch { _outlineItems = new(); }
        StateHasChanged();
    }

    private async Task ScrollToHeading(string text)
        => await JSRuntime.InvokeVoidAsync("searchInDocument", text);

    // ════════════════════════════════════════════════════════════════════════
    // RECENT FILES
    // ════════════════════════════════════════════════════════════════════════
    private async Task LoadRecentFiles()
    {
        try
        {
            var arr = await JSRuntime.InvokeAsync<RecentFileDto[]>("getRecentFiles");
            _recentFiles = arr?.Select(r => new RecentFile
            {
                Name      = r.Name,
                OpenedAt  = r.OpenedAt,
                TimeLabel = FormatRelativeTime(r.OpenedAt)
            }).ToList() ?? new();
        }
        catch { _recentFiles = new(); }
        StateHasChanged();
    }

    private async Task ClearRecentFiles()
    {
        await JSRuntime.InvokeVoidAsync("clearRecentFiles");
        _recentFiles.Clear(); StateHasChanged();
    }

    private async Task PushRecentFile(string fileName)
    {
        await JSRuntime.InvokeVoidAsync("pushRecentFile", fileName, DateTime.UtcNow.ToString("o"));
        await LoadRecentFiles();
    }

    // ════════════════════════════════════════════════════════════════════════
    // SLASH SNIPPETS
    // ════════════════════════════════════════════════════════════════════════
    private async Task InsertSnippet(int idx)
    {
        _slashPickerVisible = false; StateHasChanged();
        if (idx < 0 || idx >= _snippets.Count) return;
        await JSRuntime.InvokeVoidAsync("insertSnippetText", _snippets[idx].Body);
    }

    // ════════════════════════════════════════════════════════════════════════
    // AUTO-SAVE & RECOVERY
    // ════════════════════════════════════════════════════════════════════════
    private async Task StartAutoSaveForActiveTab()
    {
        var tab = ActiveTab;
        if (tab == null) return;
        await JSRuntime.InvokeVoidAsync("startAutoSave", tab.Id.ToString(), tab.FileName);
        _autoSaveLabel = string.Empty;
    }

    private async Task CheckForRecoveryDrafts()
    {
        try
        {
            var drafts = await JSRuntime.InvokeAsync<RecoveryDraft[]>("checkAutoSaveRecovery");
            if (drafts != null && drafts.Length > 0)
            {
                _recoveryDrafts = drafts.ToList(); _showRecoveryBanner = true;
                StateHasChanged();
            }
        }
        catch { }
    }

    private async Task RestoreFirstDraft()
    {
        var draft = _recoveryDrafts.FirstOrDefault();
        if (draft == null) return;
        var tab = ActiveTab;
        if (tab != null) { tab.FileName = draft.FileName; tab.Sfdt = draft.Sfdt; tab.IsModified = true; tab.IsEmpty = false; }
        await JSRuntime.InvokeVoidAsync("loadRecoveredDraft", draft.Sfdt);
        await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", draft.TabId);
        _recoveryDrafts.Remove(draft);
        _showRecoveryBanner = _recoveryDrafts.Count > 0;
        await StartAutoSaveForActiveTab();
        SetStatus($"✅ Restored: {draft.FileName}", false);
        StateHasChanged();
    }

    private async Task DismissRecovery()
    {
        await JSRuntime.InvokeVoidAsync("dismissAllDrafts");
        _recoveryDrafts.Clear(); _showRecoveryBanner = false; StateHasChanged();
    }

    private static string FormatRelativeTime(string? iso)
    {
        if (string.IsNullOrEmpty(iso) || !DateTime.TryParse(iso, out var dt)) return "recently";
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 1)  return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours   < 24) return $"{(int)diff.TotalHours}h ago";
        return dt.ToString("MMM d");
    }

    // ════════════════════════════════════════════════════════════════════════
    // THEME / PANES
    // ════════════════════════════════════════════════════════════════════════
    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        await JSRuntime.InvokeVoidAsync("applyTheme", _isDarkMode);
        StateHasChanged();
    }

    private void ToggleLeftPane()
    {
        _leftPaneOpen = !_leftPaneOpen; StateHasChanged();
        JSRuntime.InvokeVoidAsync("resizeEditor");
    }
    

    private async Task NewDocumentFromPanel() => await NewTab();

    private async Task OpenFileDialog()
        => await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('fileUploadInput').click()");

    // ════════════════════════════════════════════════════════════════════════
    // FILE UPLOAD
    // ════════════════════════════════════════════════════════════════════════
    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (ext is not (".docx" or ".doc" or ".rtf" or ".txt"))
        {
            SetStatus("❌ Unsupported file type.", true); return;
        }
        SetStatus("⏳ Opening document…", false);
        try
        {
            using var formContent = new MultipartFormDataContent();
            var stream = file.OpenReadStream(maxAllowedSize: 104_857_600);
            formContent.Add(new StreamContent(stream), "files", file.Name);
            var response = await Http.PostAsync("api/documenteditor/import", formContent);
            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"❌ {await response.Content.ReadAsStringAsync()}", true); return;
            }
            var sfdt     = await response.Content.ReadAsStringAsync();
            var fileName = Path.GetFileNameWithoutExtension(file.Name) + ".docx";
            var activeTab = ActiveTab;
            DocTab targetTab;
            if (activeTab != null && activeTab.IsEmpty) { targetTab = activeTab; }
            else
            {
                targetTab = new DocTab { FileName = "loading", IsEmpty = false };
                _tabs.Add(targetTab); _activeTabId = targetTab.Id;
            }
            targetTab.FileName = fileName; targetTab.Sfdt = sfdt;
            targetTab.IsModified = false;  targetTab.IsEmpty = false;
            await JSRuntime.InvokeVoidAsync("loadDocument", sfdt);
            await StartAutoSaveForActiveTab();
            await PushRecentFile(fileName);
            SetStatus($"✅ Opened: {file.Name}", false);
            StateHasChanged();
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // ════════════════════════════════════════════════════════════════════════
    // SAVE
    // ════════════════════════════════════════════════════════════════════════
    private async Task SaveDocument()
    {
        if (ActiveTab == null || ActiveTab.IsEmpty) { SetStatus("❌ No document to save.", true); return; }
        SetStatus("⏳ Saving…", false);
        try
        {
            var sfdt = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(sfdt)) { SetStatus("❌ Nothing to save.", true); return; }
            ActiveTab.Sfdt = sfdt; ActiveTab.IsModified = false;
            var response = await Http.PostAsJsonAsync("api/documenteditor/save",
                new { Content = sfdt, FileName = ActiveTab.FileName });
            if (!response.IsSuccessStatusCode) { SetStatus("❌ Save failed.", true); return; }
            var base64 = Convert.ToBase64String(await response.Content.ReadAsByteArrayAsync());
            await JSRuntime.InvokeVoidAsync("downloadFile", base64, ActiveTab.FileName);
            await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", ActiveTab.Id.ToString());
            _autoSaveLabel = string.Empty;
            SetStatus($"✅ Saved: {ActiveTab.FileName}", false);
            StateHasChanged();
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // ════════════════════════════════════════════════════════════════════════
    // CASE TRANSFORMS
    // ════════════════════════════════════════════════════════════════════════
    private async Task ApplyTitleCase()
    {
        var r = await JSRuntime.InvokeAsync<string>("applyTitleCase");
        SetStatus(r == "NO_SELECTION" ? "⚠️ Select text first." : "✅ Title Case applied.", r == "NO_SELECTION");
    }
    private async Task ApplyInitialCaps()
    {
        var r = await JSRuntime.InvokeAsync<string>("applyInitialCaps");
        SetStatus(r == "NO_SELECTION" ? "⚠️ Select text first." : "✅ Initial Caps applied.", r == "NO_SELECTION");
    }
    private async Task ApplyEssentialCaps()
    {
        var r = await JSRuntime.InvokeAsync<string>("applyEssentialCaps");
        if      (r == "NO_SELECTION")   SetStatus("⚠️ Select text first.", true);
        else if (r == "NLP_NOT_LOADED") SetStatus("❌ NLP not loaded yet.", true);
        else                            SetStatus("✅ Essential Caps applied.", false);
    }

    // ════════════════════════════════════════════════════════════════════════
    // AI CHAT
    // ════════════════════════════════════════════════════════════════════════
    private void ToggleChat()
    {
        _chatOpen = !_chatOpen; StateHasChanged();
        JSRuntime.InvokeVoidAsync("resizeEditor");
    }

    private async Task QuickAction(string action)
    {
        var selected    = await JSRuntime.InvokeAsync<string>("getSelectedText");
        bool isWholeDoc = string.IsNullOrWhiteSpace(selected);
        if (isWholeDoc) selected = await JSRuntime.InvokeAsync<string>("getDocumentText");
        if (string.IsNullOrWhiteSpace(selected))
        {
            AddMessage("assistant", "⚠️ The document appears to be empty.", null); return;
        }
        var trimmed = TrimToWordLimit(selected, 3000);
        var scope   = isWholeDoc ? "whole document" : "selection";
        var label   = isWholeDoc ? "📄 Whole document" : $"<em>{Truncate(selected, 80)}</em>";
        if (trimmed.Length < selected.Length)
            AddMessage("assistant", "⚠️ Document is large — analyzing first ~3,000 words.", null);

        string prompt = action switch
        {
            "proofread" => $"Proofread the following {scope}. List each issue with a short explanation and corrected version. If no issues, say so.\n\nText:\n{trimmed}",
            "copyedit"  => $"Copyedit the following {scope} to improve clarity, flow, and word choice. Show the improved version (labeled 'Improved version:') then briefly explain your changes.\n\nText:\n{trimmed}",
            "summarize" => $"Write a concise 1-paragraph summary of the following {scope}.\n\nText:\n{trimmed}",
            "title"     => $"Suggest 3 engaging, specific titles for the following text. Number them.\n\nText:\n{trimmed}",
            "tone"      => $"Analyze the tone of the following text. Classify it (e.g. formal, academic, casual) and briefly explain why.\n\nText:\n{trimmed}",
            _           => trimmed
        };

        var userLabel = action switch
        {
            "proofread" => $"🔍 Proofread: {label}",
            "copyedit"  => $"✏️ Copyedit: {label}",
            "summarize" => $"📋 Summarize: {label}",
            "title"     => $"💡 Suggest Title: {label}",
            "tone"      => $"🎭 Tone Check: {label}",
            _           => label
        };

        AddMessage("user", userLabel, null);
        await CallAI(prompt, extractApplicable: action == "copyedit");
    }

    private async Task SendChatMessage()
    {
        if (string.IsNullOrWhiteSpace(_chatInput) || _chatLoading) return;
        var userText = _chatInput.Trim();
        _chatInput = string.Empty;
        AddMessage("user", System.Web.HttpUtility.HtmlEncode(userText), null);
        if (IsSimpleCheck(userText)) { await RunFreeCheck(userText); return; }
        var selected = await JSRuntime.InvokeAsync<string>("getSelectedText");
        var prompt   = string.IsNullOrWhiteSpace(selected) ? userText
            : $"{userText}\n\nSelected text for context:\n{selected}";
        await CallAI(prompt, extractApplicable: false);
    }

    private async Task HandleChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await SendChatMessage();
    }

    private static bool IsSimpleCheck(string input)
    {
        var l = input.ToLower();
        return l.Contains("word count") || l.Contains("how many words") ||
               l.Contains("sentence count") || l.Contains("how long") ||
               l.Contains("character count");
    }

    private async Task RunFreeCheck(string query)
    {
        var text  = await JSRuntime.InvokeAsync<string>("getDocumentText");
        var lower = query.ToLower();
        string reply;
        if (lower.Contains("word"))
        {
            var c = string.IsNullOrWhiteSpace(text) ? 0
                : text.Split(new[]{' ','\n','\r','\t'}, StringSplitOptions.RemoveEmptyEntries).Length;
            reply = $"📊 Word count: <strong>{c:N0}</strong> words";
        }
        else if (lower.Contains("sentence"))
        {
            var c = string.IsNullOrWhiteSpace(text) ? 0
                : text.Split(new[]{'.','!','?'}, StringSplitOptions.RemoveEmptyEntries).Length;
            reply = $"📊 Sentence count: <strong>{c:N0}</strong> sentences";
        }
        else if (lower.Contains("character"))
            reply = $"📊 Character count: <strong>{text?.Length ?? 0:N0}</strong> characters";
        else
            reply = "I can answer word count, sentence count, and character count for free. For other questions I'll use the AI engine.";
        AddMessage("assistant", reply, null);
    }

    private async Task CallAI(string prompt, bool extractApplicable)
    {
        _chatLoading = true; StateHasChanged(); await ScrollChatToBottom();
        try
        {
            var response = await Http.PostAsJsonAsync("api/ai/chat", new { Prompt = prompt });
            if (!response.IsSuccessStatusCode)
            {
                AddMessage("assistant", $"❌ AI error: {await response.Content.ReadAsStringAsync()}", null); return;
            }
            var aiText = (await response.Content.ReadAsStringAsync()).Trim('"').Replace("\\n","\n").Replace("\\r","");
            AddMessage("assistant", FormatAsHtml(aiText), extractApplicable ? ExtractImprovedText(aiText) : null);
        }
        catch (Exception ex) { AddMessage("assistant", $"❌ {ex.Message}", null); }
        finally { _chatLoading = false; StateHasChanged(); await ScrollChatToBottom(); }
    }

    private async Task ApplySuggestion(string text)
    {
        await JSRuntime.InvokeVoidAsync("replaceSelectedText", text);
        SetStatus("AI suggestion applied.", false);
        AddMessage("assistant", "✅ Applied to document.", null);
    }

