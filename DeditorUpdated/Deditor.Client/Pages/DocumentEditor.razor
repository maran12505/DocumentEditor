    // ── JSInvokable callbacks ────────────────────────────────────────────────
    [JSInvokable] public void OnAutoSaved(string timeString) { _autoSaveLabel = $"✓ Saved {timeString}"; if (ActiveTab != null) ActiveTab.IsModified = true; StateHasChanged(); }
    [JSInvokable] public async Task OnEscapePressed() { if (_showFileNotFoundModal) { _showFileNotFoundModal = false; StateHasChanged(); return; } if (_focusMode) { _focusMode = false; await JSRuntime.InvokeVoidAsync("resizeEditor"); } if (_slashPickerVisible) { _slashPickerVisible = false; } StateHasChanged(); }
    [JSInvokable] public Task OnSlashTyped(double x, double y) { _slashPickerX = x; _slashPickerY = Math.Max(8, y - 275); _slashActiveIdx = 0; _slashPickerVisible = true; StateHasChanged(); return Task.CompletedTask; }
    [JSInvokable] public async Task NewTabFromJS() => await NewTab();
    [JSInvokable] public async Task OpenFileFromJS() => await OpenFileDialog();
     [JSInvokable] public void OnFileOpenedFromJS(string fileName) { if (ActiveTab != null) { ActiveTab.FileName = fileName; ActiveTab.IsEmpty = false; ActiveTab.IsModified = false; StateHasChanged(); } }
[JSInvokable] public async Task OnSaveShortcut() => await SaveDocument();
    [JSInvokable] public async Task OnSaveAsShortcut() { } // handled by JS directly
    [JSInvokable] public async Task OnSaveAsCompleted(string result)
    {
        if (ActiveTab == null) return;
        var tabId = ActiveTab.Id.ToString();
        if (result == "CANCELLED")
        {
            SetStatus("Save cancelled.", false);
        }
        else if (result.StartsWith("ERROR:"))
        {
            SetStatus($"❌ {result[6..]}", true);
        }
        else if (result.StartsWith("OK:"))
        {
            var chosenName = result[3..];
            ActiveTab.FileName   = chosenName;
            ActiveTab.IsModified = false;
            await PushRecentFile(chosenName);
            SetStatus($"✅ Saved: {chosenName}", false);
        }
        StateHasChanged();
    }

    private async Task EnterFocusMode() { _focusMode = true; _leftPaneOpen = false; _chatOpen = false; StateHasChanged(); await JSRuntime.InvokeVoidAsync("resizeEditor"); }
    private async Task ExitFocusMode() { _focusMode = false; StateHasChanged(); await JSRuntime.InvokeVoidAsync("resizeEditor"); }

    private async Task RefreshStats()
    {
        var text = await JSRuntime.InvokeAsync<string>("getDocumentText");
        if (string.IsNullOrWhiteSpace(text)) { _statWords = _statChars = _statSentences = 0; _statReadMin = "0"; _statAvgSentLen = "0"; StateHasChanged(); return; }
        var words = text.Split(new[]{' ','\n','\r','\t'}, StringSplitOptions.RemoveEmptyEntries);
        var sentences = text.Split(new[]{'.','!','?'}, StringSplitOptions.RemoveEmptyEntries);
        _statWords = words.Length; _statChars = text.Length; _statSentences = sentences.Length;
        _statReadMin = Math.Max(1, _statWords / 200).ToString();
        _statAvgSentLen = _statSentences > 0 ? Math.Round((double)_statWords / _statSentences, 1).ToString("0.0") : "0";
        StateHasChanged();
    }

    private async Task RefreshOutline() { try { var items = await JSRuntime.InvokeAsync<OutlineItem[]>("getDocumentOutline"); _outlineItems = items?.ToList() ?? new(); } catch { _outlineItems = new(); } StateHasChanged(); }
    private async Task ScrollToHeading(string text) => await JSRuntime.InvokeVoidAsync("searchInDocument", text);

    private async Task LoadRecentFiles() { try { var arr = await JSRuntime.InvokeAsync<RecentFileDto[]>("getRecentFiles"); _recentFiles = arr?.Select(r => new RecentFile { Name = r.Name, OpenedAt = r.OpenedAt, TimeLabel = FormatRelativeTime(r.OpenedAt) }).ToList() ?? new(); } catch { _recentFiles = new(); } StateHasChanged(); }
    private async Task ClearRecentFiles() { await JSRuntime.InvokeVoidAsync("clearRecentFiles"); _recentFiles.Clear(); StateHasChanged(); }
    private async Task PushRecentFile(string fileName) { await JSRuntime.InvokeVoidAsync("pushRecentFile", fileName, DateTime.UtcNow.ToString("o")); await LoadRecentFiles(); }

    private async Task InsertSnippet(int idx) { _slashPickerVisible = false; StateHasChanged(); if (idx < 0 || idx >= _snippets.Count) return; await JSRuntime.InvokeVoidAsync("insertSnippetText", _snippets[idx].Body); }

    private async Task StartAutoSaveForActiveTab() { var tab = ActiveTab; if (tab == null) return; await JSRuntime.InvokeVoidAsync("startAutoSave", tab.Id.ToString(), tab.FileName); _autoSaveLabel = string.Empty; }

    private async Task CheckForRecoveryDrafts() { try { var drafts = await JSRuntime.InvokeAsync<RecoveryDraft[]>("checkAutoSaveRecovery"); if (drafts != null && drafts.Length > 0) { _recoveryDrafts = drafts.ToList(); _showRecoveryBanner = true; StateHasChanged(); } } catch { } }

    private async Task RestoreFirstDraft()
    {
        var draft = _recoveryDrafts.FirstOrDefault(); if (draft == null) return;
        var tab = ActiveTab; if (tab != null) { tab.FileName = draft.FileName; tab.IsModified = true; tab.IsEmpty = false; await JSRuntime.InvokeVoidAsync("storeSfdtToDb", tab.Id.ToString(), draft.Sfdt); }
        await JSRuntime.InvokeVoidAsync("loadRecoveredDraft", draft.Sfdt);
        await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", draft.TabId);
        _recoveryDrafts.Remove(draft); _showRecoveryBanner = _recoveryDrafts.Count > 0;
        await StartAutoSaveForActiveTab(); SetStatus($"✅ Restored: {draft.FileName}", false); StateHasChanged();
    }

    private async Task DismissRecovery() { await JSRuntime.InvokeVoidAsync("dismissAllDrafts"); _recoveryDrafts.Clear(); _showRecoveryBanner = false; StateHasChanged(); }

    private static string FormatRelativeTime(string? iso)
    {
        if (string.IsNullOrEmpty(iso) || !DateTime.TryParse(iso, out var dt)) return "recently";
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 1) return "just now"; if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago"; return dt.ToString("MMM d");
    }

    private async Task ToggleTheme() { _isDarkMode = !_isDarkMode; await JSRuntime.InvokeVoidAsync("applyTheme", _isDarkMode); StateHasChanged(); }
    private void ToggleLeftPane() { _leftPaneOpen = !_leftPaneOpen; StateHasChanged(); JSRuntime.InvokeVoidAsync("resizeEditor"); }
    private async Task NewDocumentFromPanel() => await NewTab();
    private async Task OpenFileDialog()
    {
        // Try native File System Access API first — gives us a writable handle for Save
        var hasApi = await JSRuntime.InvokeAsync<bool>("hasFileSystemAccess");
        if (hasApi)
        {
            await OpenWithNativePicker();
            return;
        }
        // Fallback: use standard <InputFile> (no write-back handle)
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('fileUploadInput').click()");
    }

    private async Task OpenWithNativePicker()
    {
        // Determine which tab to load into
        var activeTab = ActiveTab;
        DocTab targetTab;
        if (activeTab != null && activeTab.IsEmpty)
        {
            targetTab = activeTab;
        }
        else
        {
            targetTab = new DocTab { FileName = "loading", IsEmpty = false };
            _tabs.Add(targetTab);
            _activeTabId = targetTab.Id;
            // Create a new editor instance for this tab
            await JSRuntime.InvokeVoidAsync("createEditorForTab", targetTab.Id.ToString());
            StateHasChanged();
        }

        var tabId = targetTab.Id.ToString();

        try
        {
            // Open native picker — JS stores the handle and returns file data
            var result = await JSRuntime.InvokeAsync<JsonElement>("openWithFilePicker", tabId);

            // Check for error/cancel
            if (result.TryGetProperty("error", out var errorProp))
            {
                var err = errorProp.GetString() ?? "";
                if (err == "CANCELLED")
                {
                    // Remove the tab and destroy its editor if we just created it
                    if (targetTab.FileName == "loading") { await JSRuntime.InvokeVoidAsync("destroyEditorForTab", tabId); _tabs.Remove(targetTab); if (activeTab != null) { _activeTabId = activeTab.Id; await JSRuntime.InvokeVoidAsync("switchTab", "", activeTab.Id.ToString(), activeTab.IsEmpty); } }
                    StateHasChanged();
                    return;
                }
                SetStatus($"❌ {err}", true);
                if (targetTab.FileName == "loading") { await JSRuntime.InvokeVoidAsync("destroyEditorForTab", tabId); _tabs.Remove(targetTab); if (activeTab != null) { _activeTabId = activeTab.Id; await JSRuntime.InvokeVoidAsync("switchTab", "", activeTab.Id.ToString(), activeTab.IsEmpty); } }
                StateHasChanged();
                return;
            }

            // ✅ ADD: JS already sent file to server, just read sfdt directly
var fileName = result.GetProperty("fileName").GetString() ?? "Untitled.docx";
var sfdt     = result.GetProperty("sfdt").GetString() ?? "";

if (string.IsNullOrEmpty(sfdt))
{
    SetStatus("❌ Import returned empty result.", true);
    await JSRuntime.InvokeVoidAsync("clearFileHandle", tabId);
    if (targetTab.FileName == "loading") { await JSRuntime.InvokeVoidAsync("destroyEditorForTab", tabId); _tabs.Remove(targetTab); if (activeTab != null) { _activeTabId = activeTab.Id; await JSRuntime.InvokeVoidAsync("switchTab", "", activeTab.Id.ToString(), activeTab.IsEmpty); } }
    StateHasChanged();
    return;
}

SetStatus("⏳ Opening document…", false);
StateHasChanged();

            // Keep the original filename and extension so Save writes in the correct format
            targetTab.FileName   = fileName;
            await JSRuntime.InvokeVoidAsync("storeSfdtToDb", targetTab.Id.ToString(), sfdt);
            targetTab.IsModified = false;
            targetTab.IsEmpty    = false;
            _activeTabId         = targetTab.Id;

            await JSRuntime.InvokeVoidAsync("loadDocument", sfdt);
            await StartAutoSaveForActiveTab();
            await PushRecentFile(fileName);
            SetStatus($"✅ Opened: {fileName}", false);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            SetStatus($"❌ {ex.Message}", true);
            await JSRuntime.InvokeVoidAsync("clearFileHandle", tabId);
            if (targetTab.FileName == "loading") { await JSRuntime.InvokeVoidAsync("destroyEditorForTab", tabId); _tabs.Remove(targetTab); if (activeTab != null) { _activeTabId = activeTab.Id; await JSRuntime.InvokeVoidAsync("switchTab", "", activeTab.Id.ToString(), activeTab.IsEmpty); } }
            StateHasChanged();
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File; if (file == null) return;
      var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (ext is not (".docx" or ".doc" or ".rtf" or ".txt" or ".xml" or ".sfdt"))
        {
            await JSRuntime.InvokeVoidAsync("eval",
                "alert('Unsupported file format: \"" + ext + "\"\\n\\nSupported formats:\\n• .docx (Word Document)\\n• .doc (Word 97-2003)\\n• .rtf (Rich Text Format)\\n• .txt (Plain Text)\\n• .sfdt (Syncfusion Document)')");
            return;
        }
        SetStatus("⏳ Opening document…", false);
        try
        {
            using var formContent = new MultipartFormDataContent();
            var stream = file.OpenReadStream(maxAllowedSize: 104_857_600);
            formContent.Add(new StreamContent(stream), "files", file.Name);
            var response = await Http.PostAsync("api/documenteditor/import", formContent);
            if (!response.IsSuccessStatusCode) { SetStatus($"❌ {await response.Content.ReadAsStringAsync()}", true); return; }
            var sfdt = await response.Content.ReadAsStringAsync();
            var fileName = file.Name; // Keep original name and extension
            var activeTab = ActiveTab; DocTab targetTab;
            if (activeTab != null && activeTab.IsEmpty) { targetTab = activeTab; }
            else { targetTab = new DocTab { FileName = "loading", IsEmpty = false }; _tabs.Add(targetTab); _activeTabId = targetTab.Id; await JSRuntime.InvokeVoidAsync("createEditorForTab", targetTab.Id.ToString()); }
            targetTab.FileName = fileName; targetTab.IsModified = false; targetTab.IsEmpty = false;
            await JSRuntime.InvokeVoidAsync("storeSfdtToDb", targetTab.Id.ToString(), sfdt);
            // File opened via upload — no file handle, so first Save will trigger Save As
            await JSRuntime.InvokeVoidAsync("clearFileHandle", targetTab.Id.ToString());
            await JSRuntime.InvokeVoidAsync("loadDocument", sfdt);
            await StartAutoSaveForActiveTab(); await PushRecentFile(fileName);
            SetStatus($"✅ Opened: {file.Name}", false); StateHasChanged();
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // SAVE — Notepad-style logic:
    //   1. If file handle exists → overwrite silently (no picker)
    //   2. If no handle → redirect to Save As (opens OS file picker)
    // ═════════════════════════════════════════════════════════════════════════
    private async Task SaveDocument()
    {
        if (ActiveTab == null) { SetStatus("❌ No document to save.", true); return; }

        // If tab was marked empty (new doc), check if user actually typed something
        if (ActiveTab.IsEmpty)
        {
            var check = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(check)) { SetStatus("❌ No document to save.", true); return; }
            ActiveTab.IsEmpty = false; // user has content now
        }

        var tabId = ActiveTab.Id.ToString();

        // Check if we have File System Access API and an existing handle
        var hasApi    = await JSRuntime.InvokeAsync<bool>("hasFileSystemAccess");
        var hasHandle = hasApi && await JSRuntime.InvokeAsync<bool>("hasFileHandle", tabId);

if (!hasHandle)
        {
            // No previous save location → use download fallback
            await FallbackDownloadSave();
            return;
        }

        // We have a handle — convert to bytes on server, then overwrite the file
        SetStatus("⏳ Saving…", false);
        try
        {
            var sfdt = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(sfdt)) { SetStatus("❌ Nothing to save.", true); return; }
            await JSRuntime.InvokeVoidAsync("storeSfdtToDb", ActiveTab.Id.ToString(), sfdt);

            var response = await Http.PostAsJsonAsync("api/documenteditor/save",
                new { Content = sfdt, FileName = ActiveTab.FileName });
            if (!response.IsSuccessStatusCode) { SetStatus("❌ Save failed.", true); return; }

            var base64 = Convert.ToBase64String(await response.Content.ReadAsByteArrayAsync());
            var result  = await JSRuntime.InvokeAsync<string>("saveToExistingHandle", tabId, base64);

            if (result == "OK")
            {
                ActiveTab.IsModified = false;
                await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", tabId);
                _autoSaveLabel = string.Empty;
                SetStatus($"✅ Saved: {ActiveTab.FileName}", false);
            }
            else if (result == "DELETED")
            {
                // File was deleted from disk — show Notepad-style "Cannot find" popup
                _missingFileName = ActiveTab.FileName;
                _showFileNotFoundModal = true;
                SetStatus("", false);
            }
            else if (result == "NO_HANDLE")
            {
                // Handle was lost (permission denied, etc.) → fall back to Save As
                await SaveAsDocument();
                return;
            }
            else
            {
                SetStatus($"❌ {result}", true);
            }
            StateHasChanged();
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // SAVE AS — Always opens OS native file picker
    // ═════════════════════════════════════════════════════════════════════════
    private async Task SaveAsDocument()
    {
        if (ActiveTab == null) { SetStatus("❌ No document to save.", true); return; }

        // If tab was marked empty, check if user actually typed something
        if (ActiveTab.IsEmpty)
        {
            var check = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(check)) { SetStatus("❌ No document to save.", true); return; }
            ActiveTab.IsEmpty = false;
        }

        var hasApi = await JSRuntime.InvokeAsync<bool>("hasFileSystemAccess");
        if (!hasApi)
        {
            await FallbackDownloadSave();
            return;
        }

        var tabId     = ActiveTab.Id.ToString();
        var formatExt = Path.GetExtension(ActiveTab.FileName).ToLowerInvariant();
        if (formatExt is not (".docx" or ".doc" or ".rtf" or ".txt" or ".xml")) formatExt = ".docx";

        SetStatus("⏳ Saving…", false);
        StateHasChanged();

        try
        {
            // Single JS call: opens picker immediately (preserves user gesture),
            // then serializes, POSTs to server, writes to file
            var result = await JSRuntime.InvokeAsync<string>(
                "saveAsComplete", tabId, ActiveTab.FileName, formatExt, "api/documenteditor/save");

            if (result == "CANCELLED")
            {
                SetStatus("Save cancelled.", false);
            }
            else if (result.StartsWith("ERROR:"))
            {
                SetStatus($"❌ {result[6..]}", true);
            }
            else if (result.StartsWith("OK:"))
            {
                var chosenName = result[3..];
                ActiveTab.FileName   = chosenName;
                ActiveTab.IsModified = false;
                await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", tabId);
                _autoSaveLabel = string.Empty;
                await StartAutoSaveForActiveTab();
                await PushRecentFile(chosenName);
                SetStatus($"✅ Saved: {chosenName}", false);
            }
            StateHasChanged();
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // Fallback for browsers without File System Access API
    private async Task FallbackDownloadSave()
    {
        SetStatus("⏳ Saving…", false);
        try
        {
            var sfdt = await JSRuntime.InvokeAsync<string>("getDocumentContent");
            if (string.IsNullOrEmpty(sfdt)) { SetStatus("❌ Nothing to save.", true); return; }
            ActiveTab!.IsModified = false;
            var response = await Http.PostAsJsonAsync("api/documenteditor/save",
                new { Content = sfdt, FileName = ActiveTab.FileName });
            if (!response.IsSuccessStatusCode) { SetStatus("❌ Save failed.", true); return; }
            var base64 = Convert.ToBase64String(await response.Content.ReadAsByteArrayAsync());
            await JSRuntime.InvokeVoidAsync("downloadFile", base64, ActiveTab.FileName);
            await JSRuntime.InvokeVoidAsync("clearAutoSaveDraft", ActiveTab.Id.ToString());
            _autoSaveLabel = string.Empty;
            SetStatus($"✅ Saved: {ActiveTab.FileName}", false); StateHasChanged();
        }
        catch (Exception ex) { SetStatus($"❌ {ex.Message}", true); }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // FILE NOT FOUND MODAL — handles deleted file scenario
    // ═════════════════════════════════════════════════════════════════════════
